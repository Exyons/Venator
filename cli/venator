DESIGN_SHIPPED_DIR = _find_shipped_dir("designs")
DESIGN_USER_DIR    = _real_home() / ".config" / "venator" / "designs"


def list_designs() -> dict:
    """Return {name: path}. Shipped first; user overrides shipped on conflict."""
    out: dict[str, Path] = {}
    for d in (DESIGN_SHIPPED_DIR, DESIGN_USER_DIR):
        if not d.exists():
            continue
        for f in sorted(d.iterdir()):
            if f.suffix not in (".py", ".json"):
                continue
            if f.stem.startswith("_") or f.stem == "README":
                continue
            out[f.stem] = f
    return out


def find_design(arg: str) -> Path:
    p = Path(arg)
    if p.suffix in (".py", ".json") and p.exists():
        return p
    designs = list_designs()
    if arg in designs:
        return designs[arg]
    names = ", ".join(sorted(designs)) or "<none>"
    die(f"design {arg!r} not found. Available: {names}\n"
        f"  Drop .py or .json in {DESIGN_USER_DIR} to add your own.")


def design_from_json(path: Path, keymap: dict, num_cells: int) -> bytes:
    """Render a declarative JSON design into a 128*3 byte buffer.

    Schema:
      {
        "name": "...",
        "description": "...",
        "base_color": "#RRGGBB",        # optional, default #000000
        "cells":  {"5": "#RRGGBB", ...} # optional, raw cell index -> colour
        "keys":   {"W": "#RRGGBB", ...} # optional, name -> colour via keymap
      }
    Layering order: base_color fills the whole frame, then `cells`
    overrides, then `keys` overrides (so a named key beats a cell-index
    write to the same physical cell).
    """
    try:
        spec = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError) as e:
        die(f"bad design {path}: {e}")

    base = spec.get("base_color", "#000000")
    r, g, b = parse_rgb(base)
    buf = bytearray([r, g, b] * num_cells)

    # cell-indexed overrides
    for k, col in spec.get("cells", {}).items():
        try:
            idx = int(k)
        except ValueError:
            print(f"  note: design {path.name}: cell key {k!r} isn't an integer", file=sys.stderr)
            continue
        if not (0 <= idx < num_cells):
            continue
        cr, cg, cb = parse_rgb(col)
        buf[idx * 3 + 0] = cr
        buf[idx * 3 + 1] = cg
        buf[idx * 3 + 2] = cb

    # named-key overrides
    keys = keymap.get("keys", {})
    ci_index = {n.lower(): n for n in keys}
    missing = []
    for name, col in spec.get("keys", {}).items():
        cell = keys.get(name)
        if cell is None:
            cell = keys.get(ci_index.get(name.lower(), ""))
        if cell is None:
            missing.append(name); continue
        idx = int(cell)
        if not (0 <= idx < num_cells):
            continue
        cr, cg, cb = parse_rgb(col)
        buf[idx * 3 + 0] = cr
        buf[idx * 3 + 1] = cg
        buf[idx * 3 + 2] = cb

    if missing:
        print(f"  note: keymap is missing {len(missing)} key{'s' if len(missing) != 1 else ''} "
              f"used by this design: {', '.join(missing)}\n"
              f"        run `venator map discover` to fill them in.",
              file=sys.stderr)

    return bytes(buf)


def cmd_rgb_design(args: argparse.Namespace) -> None:
    if args.list:
        designs = list_designs()
        if not designs:
            print(f"  no designs installed")
            print(f"  shipped: {DESIGN_SHIPPED_DIR}")
            print(f"  user:    {DESIGN_USER_DIR}")
            return
        for name, path in sorted(designs.items()):
            origin = "shipped" if path.parent == DESIGN_SHIPPED_DIR else "user"
            print(f"  {name:24s} [{origin}] {path.suffix.lstrip('.')}  {path}")
        return
    if not args.name:
        die("usage: venator rgb design <name> | rgb design --list")

    path = find_design(args.name)
    keymap = load_keymap()

    if path.suffix == ".json":
        buf = design_from_json(path, keymap, 128)
        spec = json.loads(path.read_text())
        name = spec.get("name", args.name)
    elif path.suffix == ".py":
        mod = load_animation(path)   # same loader; designs reuse the render() contract
        try:
            buf = mod.render(0, 128, keymap)
        except Exception as e:
            die(f"{path}: render() crashed: {e!r}")
        if not isinstance(buf, (bytes, bytearray)) or len(buf) != PERKEY_BYTES:
            die(f"{path}: render() must return {PERKEY_BYTES} bytes")
        name = getattr(mod, "NAME", args.name)
    else:
        die(f"unsupported design type: {path.suffix}")

    stop_background()
    dev = find_device()
    write_bin_attr(dev, "frame", bytes(buf))
    write_text_attr(dev, "mode", "perkey")
    if args.brightness is not None:
        write_text_attr(dev, "brightness", str(args.brightness))
    commit(dev)
    save_default(dev, timeout=args.timeout)
    start_keepalive(args.timeout)
    print(f"applied design {name!r}")


