# The `name=acer` hwmon device that the mainline acer-wmi driver
# creates doesn't label its inputs (no fan*_label / temp*_label files),
# so the kernel exposes them as opaque fan1/fan2/temp1/temp2/temp3.
# These mappings are derived from cross-checking against PredatorSense
# V3 source maps and from running fan stress tests on a PH16-71:
#
#   fan1  = left  blower  (intakes cool air over the CPU heatsink)
#   fan2  = right blower  (intakes over the GPU heatsink)
#   temp1 = CPU  package sensor (matches coretemp's Package id 0)
#   temp2 = GPU  sensor — reads 0 when the dGPU is in D3cold / power
#           saving; populated when the dGPU is active
#   temp3 = chassis / system ambient (palmrest / motherboard area)
#
# Codenames in firmware (so power users can grep DSDT):
#   fan1 -> CPUF / EFAN  (Embedded Controller fan tach 0x00..0x07)
#   fan2 -> GPUF         (EC fan tach 0x10..0x17)
#   temp1 -> CTMP        (EC byte 0x20)
#   temp2 -> GTMP        (EC byte 0x21)
#   temp3 -> STMP        (EC byte 0x22)
ACER_HWMON_FANS = {
    1: ("fan1", "left  / CPU blower"),
    2: ("fan2", "right / GPU blower"),
}
ACER_HWMON_TEMPS = {
    1: ("CPU      (acer/temp1, EC CTMP)",  "cpu"),
    2: ("GPU      (acer/temp2, EC GTMP)",  "gpu"),
    3: ("chassis  (acer/temp3, EC STMP)",  "sys"),
}


def cmd_thermal(_: argparse.Namespace) -> None:
    hwm = _find_acer_hwmon()
    if hwm is None:
        print("acer hwmon: (not found; is acer-wmi loaded?)")
    else:
        print(f"chassis sensors  ({hwm}, name=acer):")
        for i, (_short, descr) in ACER_HWMON_FANS.items():
            v = _read_first_line(hwm / f"fan{i}_input")
            if v:
                print(f"  fan{i}  {descr:30s}  {int(v):>5} rpm")
        for i, (label, _short) in ACER_HWMON_TEMPS.items():
            v = _read_first_line(hwm / f"temp{i}_input")
            if not v:
                continue
            if v == "0":
                print(f"  temp{i} {label:38s}     —   (idle / D3cold)")
            else:
                print(f"  temp{i} {label:38s}  {int(v)//1000:>3} °C")
    # CPU package temp from coretemp / k10temp — same physical sensor
    # as acer/temp1 but read directly off the CPU instead of via EC.
    print()
    for h in sorted(glob.glob("/sys/class/hwmon/hwmon*")):
        name = _read_first_line(Path(h, "name"))
        if name in ("coretemp", "k10temp"):
            v = _read_first_line(Path(h, "temp1_input"))
            label = _read_first_line(Path(h, "temp1_label")) or "package"
            if v:
                print(f"  cpu  {f'({label})':32s}  {int(v)//1000:>3} °C")
    for h in sorted(glob.glob("/sys/class/hwmon/hwmon*")):
        name = _read_first_line(Path(h, "name"))
        if name == "nvme":
            v = _read_first_line(Path(h, "temp1_input"))
            if v:
                print(f"  nvme {' ':32s}  {int(v)//1000:>3} °C")


def cmd_fan(_: argparse.Namespace) -> None:
