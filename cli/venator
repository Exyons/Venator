# ---------------------------------------------------- lightbar (rear EC RGB)
#
# /sys/class/venator/lightbar0/{mode, brightness, color, speed, direction,
# apply, set, modes}. The `set` attr is the fast path — single write
# atomically updates all five fields and commits. `apply` commits the
# currently cached state without changing it.

# Firmware-supported lightbar effects (byte 0 of the
# SetGamingKBBacklight 16-byte buffer). IDs are NON-CONTIGUOUS —
# 0x00..0x07 are the eight animated effects + off, 0xFF is the
# "Direct" / Static mode. The kernel's lb_modes_catalog accepts
# these exact names.
LB_MODE_IDS = {
    "off":       0x00,
    "breathing": 0x01,
    "neon":      0x02,
    "rainbow":   0x03,
    "wave":      0x04,
    "ripple":    0x05,
    "scanner":   0x06,
    "strobe":    0x07,
    "static":    0xff,
}
LB_MODES = tuple(LB_MODE_IDS.keys())


def _lb_path(attr: str) -> Path:
    return VENATOR_LIGHTBAR_DIR / attr


def _require_lightbar() -> None:
    if not VENATOR_LIGHTBAR_DIR.exists():
        die("no /sys/class/venator/lightbar0 — reload venator "
            "(your kernel may not have built the WMBH lightbar half, "
            "or this firmware doesn't expose the lightbar method)")


def _hex_to_rgb(s: str) -> tuple[int, int, int]:
    s = s.strip().lstrip("#")
    if len(s) != 6:
        die(f"colour must be RRGGBB hex, got {s!r}")
    try:
        return int(s[0:2], 16), int(s[2:4], 16), int(s[4:6], 16)
    except ValueError:
        die(f"colour must be RRGGBB hex, got {s!r}")


def _write_lb(attr: str, value: str) -> None:
    p = _lb_path(attr)
    if not p.exists():
        die(f"sysfs attr {p} doesn't exist — your kernel module is "
            f"older than this CLI. Rebuild + reload it:\n"
            f"  sudo make module-install\n"
            f"  sudo modprobe -r venator && sudo modprobe venator\n"
            f"  ls /sys/class/venator/lightbar0/   # should now list '{attr}'")
    try:
        p.write_text(value)
    except PermissionError:
        die(f"permission denied writing {p}.\n"
            f"  - confirm you're in the 'venator' group:  groups | grep venator\n"
            f"  - reload udev:  sudo udevadm control --reload && "
            f"sudo udevadm trigger -s venator\n"
            f"  - if still failing: sudo chmod g+w {p}")
    except OSError as e:
        die(f"failed to write {attr}: {e}")


def cmd_lightbar_status(_: argparse.Namespace) -> None:
    _require_lightbar()
    for attr in ("mode", "brightness", "speed", "direction", "color"):
        p = _lb_path(attr)
        if p.exists():
            print(f"  {attr:11s} {_read_first_line(p)}")


def cmd_lightbar_off(_: argparse.Namespace) -> None:
    _require_lightbar()
    _write_lb("mode", "off")
    _write_lb("apply", "1")
    _autosave_lightbar()
    print("lightbar: off")


def _validate_lb_mode(name: str) -> str:
    """Normalise + validate a user-supplied mode name. The kernel
    accepts the same names — see lb_modes_catalog in
    venator-gaming.c.
    """
    n = name.strip().lower()
    if n not in LB_MODES:
        die(f"unknown mode {name!r}; known: {', '.join(LB_MODES)}")
    return n


def cmd_lightbar_mode(args: argparse.Namespace) -> None:
    _require_lightbar()
    name = _validate_lb_mode(args.name)
    _write_lb("mode", name)
    _write_lb("apply", "1")
    _autosave_lightbar()
    print(f"lightbar mode: {_read_first_line(_lb_path('mode'))}")


def cmd_lightbar_color(args: argparse.Namespace) -> None:
    _require_lightbar()
    r, g, b = _hex_to_rgb(args.color)
    _write_lb("color", f"{r:02x}{g:02x}{b:02x}")
    _write_lb("apply", "1")
    _autosave_lightbar()
    print(f"lightbar color: #{r:02x}{g:02x}{b:02x}")


def cmd_lightbar_brightness(args: argparse.Namespace) -> None:
    _require_lightbar()
    v = int(args.value)
    if not 0 <= v <= 255:
        die("brightness must be 0..255")
    _write_lb("brightness", str(v))
    _write_lb("apply", "1")
    _autosave_lightbar()
    print(f"lightbar brightness: {v}")


def cmd_lightbar_speed(args: argparse.Namespace) -> None:
    _require_lightbar()
    v = int(args.value)
    if not 0 <= v <= 255:
        die("speed must be 0..255")
    _write_lb("speed", str(v))
    _write_lb("apply", "1")
    _autosave_lightbar()
    print(f"lightbar speed: {v}")


def cmd_lightbar_set(args: argparse.Namespace) -> None:
    """Atomic update — single write to /set."""
    _require_lightbar()
    if args.mode is None and args.color is None:
        die("provide at least --mode or --color")

    # Read current state for defaults
    current_mode = _read_first_line(_lb_path("mode")) or "breathing"
    current_b = int(_read_first_line(_lb_path("brightness")) or "100")
    current_s = int(_read_first_line(_lb_path("speed")) or "5")
    cur_hex = _read_first_line(_lb_path("color")) or "ff0000"
    cur_r = int(cur_hex[0:2], 16)
    cur_g = int(cur_hex[2:4], 16)
    cur_b = int(cur_hex[4:6], 16)

    if args.mode is not None:
        name = _validate_lb_mode(args.mode)
    else:
        name = current_mode if current_mode in LB_MODE_IDS else "breathing"
    mode_id = LB_MODE_IDS[name]

    if args.color is not None:
        r, g, b = _hex_to_rgb(args.color)
    else:
        r, g, b = cur_r, cur_g, cur_b

    bright = args.brightness if args.brightness is not None else current_b
    speed = args.speed if args.speed is not None else current_s
    if not 0 <= bright <= 255:
        die("brightness must be 0..255")
    if not 0 <= speed <= 255:
        die("speed must be 0..255")

    _write_lb("set", f"{mode_id} {bright} {speed} {r} {g} {b}")
    _autosave_lightbar()
    print(f"lightbar: mode={name} "
          f"color=#{r:02x}{g:02x}{b:02x} bright={bright} speed={speed}")


def cmd_lightbar_apply(_: argparse.Namespace) -> None:
    _require_lightbar()
    _write_lb("apply", "1")
    _autosave_lightbar()
    print("lightbar: applied current state")


def cmd_lightbar_wake(args: argparse.Namespace) -> None:
    """Recover a stuck-off lightbar.

    The firmware sometimes ends up in a "logical off" state where
    `mode static` and `mode breathing` both come back silently
    successful but the strip stays dark. (Easiest way to get there:
    write the `2 10 00 00 00 00 00 f5 ff` SetGamingLED reset that
    AcerECLightbarController uses internally.) On the first session
    after that, only the FULL init sequence — mode breathing once,
    then whatever you actually want — gets the strip lit again. This
    command does exactly that.
    """
    _require_lightbar()
    # breathing → static (the sequence empirically observed to wake the
    # strip after a SetGamingLED reset)
    _write_lb("set", "1 100 5 255 0 0")
    time.sleep(0.3)
    target = (args.mode or "static").strip().lower()
    if target not in LB_MODE_IDS:
        die(f"unknown mode {target!r}; known: {', '.join(LB_MODES)}")
    mode_id = LB_MODE_IDS[target]
    # 100 brightness, 5 speed, R=FF G=00 B=00 — predictable wake state
    _write_lb("set", f"{mode_id} 100 5 255 0 0")
    _autosave_lightbar()
    print(f"lightbar woken (mode={target}, red, brightness 100)")


# ---- unified themes (keyboard + lightbar in one shot) -----------------------

def _unified_dirs() -> list[Path]:
    """Search order: user overrides, source checkout, system installs."""
    out: list[Path] = []
    cfg = _real_home() / ".config" / "venator" / "designs" / "unified"
    if cfg.is_dir():
        out.append(cfg)
    here = Path(__file__).resolve().parent
    for cand in (here / "designs" / "unified",
                 Path("/usr/local/share/venator/designs/unified"),
                 Path("/usr/share/venator/designs/unified")):
        if cand.is_dir():
            out.append(cand)
    return out


def _find_unified(name_or_path: str) -> Path:
    p = Path(name_or_path)
    if p.suffix == ".json" and p.is_file():
        return p
    name = name_or_path
    if not name.endswith(".json"):
        name = name + ".json"
    for d in _unified_dirs():
        cand = d / name
        if cand.is_file():
            return cand
    die(f"unified theme {name_or_path!r} not found. Try "
        f"`venator unified list`.")


def _list_unified() -> dict[str, Path]:
    out: dict[str, Path] = {}
    for d in _unified_dirs():
        for f in sorted(d.glob("*.json")):
            out.setdefault(f.stem, f)
    return out


def cmd_unified_list(_: argparse.Namespace) -> None:
    themes = _list_unified()
    if not themes:
        print("no unified themes found")
        return
    for name, path in sorted(themes.items()):
        try:
            data = json.loads(path.read_text())
            desc = data.get("description", "")
        except (OSError, ValueError):
            desc = "(failed to parse)"
        print(f"  {name:18s}  {desc}")


def _apply_keyboard_section(kb: dict, timeout: int) -> None:
    """Apply the 'keyboard' half of a unified theme."""
    if not isinstance(kb, dict):
        return
    mode = (kb.get("mode") or "").strip().lower()
    color = (kb.get("color") or "").lstrip("#")
    try:
        bright = int(kb.get("brightness", 200))
    except (TypeError, ValueError):
        bright = 200
    if mode == "off":
        # Use the canonical off path so background workers are stopped.
        subprocess.run([sys.argv[0], "rgb", "off"],
                       stdout=subprocess.DEVNULL,
                       stderr=subprocess.DEVNULL, timeout=5)
        return
    if mode == "static":
        # Static is its own command; `rgb effect` explicitly rejects it.
        args = [sys.argv[0], "rgb", "static", "#" + (color or "ff0000"),
                "--brightness", str(bright)]
        if timeout > 0:
            args += ["--timeout", str(timeout)]
    else:
        # Firmware effect (breathing / rainbow / snake / ...).
        args = [sys.argv[0], "rgb", "effect", mode]
        if color:
            args += ["--color", color]
        args += ["--brightness", str(bright)]
        if timeout > 0:
            args += ["--timeout", str(timeout)]
    try:
        subprocess.run(args, timeout=10)
    except Exception as e:
        print(f"  keyboard half failed: {e}", file=sys.stderr)


def _apply_lightbar_section(lb: dict) -> None:
    """Apply the 'lightbar' half of a unified theme."""
    if not isinstance(lb, dict):
        return
    if not VENATOR_LIGHTBAR_DIR.exists():
        print("  lightbar half skipped: no /sys/class/venator/lightbar0")
        return
    mode_name = (lb.get("mode") or "").strip().lower()
    if mode_name not in LB_MODE_IDS:
        print(f"  lightbar half skipped: unknown mode {mode_name!r}")
        return
    mode_id = LB_MODE_IDS[mode_name]
    try:
        bright = int(lb.get("brightness", 100))
    except (TypeError, ValueError):
        bright = 100
    try:
        speed = int(lb.get("speed", 5))
    except (TypeError, ValueError):
        speed = 5
    color = (lb.get("color") or "ff0000").lstrip("#")
    try:
        r = int(color[0:2], 16); g = int(color[2:4], 16); b = int(color[4:6], 16)
    except (ValueError, IndexError):
        r, g, b = 0xff, 0, 0
    try:
        _write_lb("set", f"{mode_id} {bright} {speed} {r} {g} {b}")
        _autosave_lightbar()
    except SystemExit:
        pass


def cmd_unified_apply(args: argparse.Namespace) -> None:
    path = _find_unified(args.name)
    try:
        theme = json.loads(path.read_text())
    except (OSError, ValueError) as e:
        die(f"failed to read theme {path}: {e}")
    timeout = args.timeout if args.timeout is not None else 0
    print(f"applying unified theme: {theme.get('name', path.stem)}")
    if theme.get("description"):
        print(f"  {theme['description']}")
    if "keyboard" in theme:
        _apply_keyboard_section(theme["keyboard"], timeout)
    if "lightbar" in theme:
        _apply_lightbar_section(theme["lightbar"])
    print("done.")


def cmd_unified_save(args: argparse.Namespace) -> None:
    """Snapshot the current keyboard + lightbar state into a new
    unified-theme JSON under ~/.config/venator/designs/unified/.
    """
    dev = find_device()
    kb = {
        "mode":  read_text_attr(dev, "mode"),
        "color": "#" + read_text_attr(dev, "color"),
        "brightness": int(read_text_attr(dev, "brightness") or "200"),
    }
    lb = _snapshot_lightbar()
    if lb is not None:
        lb_out = {
            "mode":       lb.get("mode"),
            "color":      "#" + lb.get("color", "ff0000"),
            "brightness": int(lb.get("brightness", "100")),
            "speed":      int(lb.get("speed", "5")),
        }
    else:
        lb_out = None
    theme = {
        "name":        args.name,
        "description": args.description or
                       f"saved snapshot from {datetime.datetime.now():%Y-%m-%d}",
        "keyboard":    kb,
    }
    if lb_out is not None:
        theme["lightbar"] = lb_out
    dest_dir = _real_home() / ".config" / "venator" / "designs" / "unified"
    dest_dir.mkdir(parents=True, exist_ok=True)
    _chown_to_invoker(dest_dir.parent.parent)
    _chown_to_invoker(dest_dir.parent)
    _chown_to_invoker(dest_dir)
    dest = dest_dir / f"{args.name}.json"
    dest.write_text(json.dumps(theme, indent=2, sort_keys=True))
    _chown_to_invoker(dest)
    print(f"saved unified theme: {dest}")


