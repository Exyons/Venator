def cmd_rgb_image(args: argparse.Namespace) -> None:
    try:
        from PIL import Image
    except ImportError:
        die("`venator rgb image` needs Pillow.\n"
            "  Fedora:  sudo dnf install python3-pillow\n"
            "  Ubuntu:  sudo apt install python3-pil\n"
            "  Arch:    sudo pacman -S python-pillow")
    try:
        img = Image.open(args.path).convert("RGB")
    except (FileNotFoundError, OSError) as e:
        die(f"cannot open {args.path}: {e}")
    # Scale to 128x1 -- one pixel per cell. The 128 cells don't map
    # spatially to physical keys (yet -- that needs an extension to
    # keymap.json), so the image renders as a 1D scan across the cell
    # array. Once a spatial layout file exists, this becomes a 2D
    # resize + per-cell pick.
    img = img.resize((128, 1), Image.LANCZOS)
    buf = bytearray()
    for x in range(128):
        r, g, b = img.getpixel((x, 0))
        buf.extend([r, g, b])
    stop_background()
    dev = find_device()
    write_bin_attr(dev, "frame", bytes(buf))
    write_text_attr(dev, "mode", "perkey")
    if args.brightness is not None:
        write_text_attr(dev, "brightness", str(args.brightness))
    commit(dev)
    save_default(dev, timeout=args.timeout)
    start_keepalive(args.timeout)


