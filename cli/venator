def cmd_map_discover(args: argparse.Namespace) -> None:
    """Light one cell at a time and ask the user which physical key lit up.

    Writes the answer into the keymap. Restores the previous state on exit.
    Backs up the current frame+mode+colour+brightness; restores on quit
    (whether clean exit or Ctrl-C) so the user's setup isn't trampled.
    """
    dev = find_device()

    # Backup current state for restoration on exit.
    backup_mode       = read_text_attr(dev, "mode")
    backup_color      = read_text_attr(dev, "color")
    backup_brightness = read_text_attr(dev, "brightness")
    try:
        backup_frame = (dev / "frame").read_bytes()
    except OSError:
        backup_frame = None

    km = load_keymap()
    km.setdefault("model", "Predator PH16-71")
    km.setdefault("num_cells", 128)
    km.setdefault("keys", {})

    start = max(0, args.start)
    end   = min(km["num_cells"], args.end if args.end > 0 else km["num_cells"])
    cur   = start
    history: list[int] = []

    # Boost brightness so the lit cell is unambiguous.
    write_text_attr(dev, "brightness", "255")

    print(f"discovery: cells {start}..{end-1}  ({len(km['keys'])} already mapped)")
    print("  Type the key name for the lit cell. Slash commands:")
    print("    (just press Enter)   keep existing mapping (if any), advance one cell")
    print("    /clear               remove the mapping for this cell, advance")
    print("    /back                go back one cell")
    print("    /jump <N>            jump to cell N")
    print("    /show                list mappings so far")
    print("    /save                save and continue")
    print("    /quit                save and exit")
    print("    /                    (one char alone) record this cell as the '/' key")
    print()

    def cell_by_index(c: int) -> str | None:
        for name, idx in km["keys"].items():
            if int(idx) == c:
                return name
        return None

    try:
        while cur < end:
            # Light only this cell, in white.
            frame = bytearray(PERKEY_BYTES)
            frame[cur * 3 + 0] = 0xff
            frame[cur * 3 + 1] = 0xff
            frame[cur * 3 + 2] = 0xff
            write_bin_attr(dev, "frame", bytes(frame))
            write_text_attr(dev, "mode", "perkey")
            commit(dev)

            existing = cell_by_index(cur)
            prompt = f"[cell {cur:3d}"
            if existing:
                prompt += f" = {existing!r}"
            prompt += "] "
            try:
                inp = input(prompt).strip()
            except EOFError:
                print()
                break

            if not inp:
                # Empty input = keep existing mapping (if any), just advance.
                # Use /clear to actively remove a mapping.
                history.append(cur); cur += 1; continue

            # Single '/' is the literal slash key. '/<word>' is a command.
            if inp.startswith("/") and len(inp) > 1:
                cmd = inp[1:].strip().lower()
                if cmd == "back":
                    cur = history.pop() if history else max(start, cur - 1)
                    continue
                if cmd == "clear":
                    if existing:
                        del km["keys"][existing]
                        print(f"  removed mapping for cell {cur} ({existing!r})")
                    else:
                        print(f"  (cell {cur} not mapped)")
                    history.append(cur); cur += 1; continue
                if cmd.startswith("jump"):
                    parts = cmd.split()
                    try:
                        target = int(parts[1])
                    except (IndexError, ValueError):
                        print("  usage: /jump <N>"); continue
                    if not (start <= target < end):
                        print(f"  out of range [{start}, {end-1}]"); continue
                    history.append(cur); cur = target; continue
                if cmd == "show":
                    for n, c in sorted(km["keys"].items(), key=lambda kv: int(kv[1])):
                        print(f"    cell {int(c):3d}  ->  {n}")
                    continue
                if cmd == "save":
                    save_keymap(km); print(f"  saved ({len(km['keys'])} keys)"); continue
                if cmd in ("quit", "q"):
                    break
                print(f"  unknown command /{cmd}"); continue

            # Anything else is a key name (case preserved). This includes a
            # bare "/" for the slash key.
            if inp in km["keys"] and int(km["keys"][inp]) != cur:
                print(f"  note: {inp!r} was at cell {int(km['keys'][inp])}, reassigning to {cur}")
            if existing and existing != inp:
                del km["keys"][existing]
            km["keys"][inp] = cur
            history.append(cur); cur += 1
    except KeyboardInterrupt:
        print()
    finally:
        # Save whatever we collected.
        p = save_keymap(km)
        # Restore prior visual state.
        if backup_frame is not None:
            try:
                write_bin_attr(dev, "frame", backup_frame[:PERKEY_BYTES])
            except SystemExit:
                pass
        if backup_brightness:
            try: write_text_attr(dev, "brightness", backup_brightness)
            except SystemExit: pass
        if backup_color:
            try: write_text_attr(dev, "color", backup_color)
            except SystemExit: pass
        if backup_mode:
            try: write_text_attr(dev, "mode", backup_mode)
            except SystemExit: pass
        try: commit(dev)
        except SystemExit: pass
        print(f"\nsaved {len(km['keys'])} mappings to {p}")


# -------------------------------------------------------------- profiles

PROFILE_KEYS = ("mode", "color", "brightness", "effect_id")


# ---------------------------------------------------- power / thermal / battery
#
# Everything in this section talks to *mainline* kernel interfaces — the
# Predator-specific bits are already exposed by `acer-wmi` (turbo +
# fans + temps) and `acer_wmi_battery` (charge limit, if loaded). We
# don't go through our kernel module here. The CLI just wraps the
# sysfs paths so users get one tool instead of remembering five paths.

PLATFORM_PROFILE = Path("/sys/firmware/acpi/platform_profile")
PLATFORM_PROFILE_CHOICES = Path("/sys/firmware/acpi/platform_profile_choices")

# Friendly aliases (left) → exact platform_profile_choice (right). The
# right-hand side must exist in PLATFORM_PROFILE_CHOICES on the target
# board, else we fall through to the literal value the user typed.
PROFILE_ALIASES = {
    "eco":         "low-power",
    "power-saver": "low-power",
    "quiet":       "quiet",
    "default":     "balanced",
    "balanced":    "balanced",
    "performance": "balanced-performance",  # PredatorSense's "Performance"
    "turbo":       "performance",            # PredatorSense's "Turbo"
}


def _read_first_line(p: Path, default: str = "") -> str:
    try:
        return p.read_text().strip()
    except (FileNotFoundError, PermissionError, OSError):
        return default


def _find_acer_hwmon() -> Path | None:
    """Locate the hwmon directory whose `name` reads `acer` — this is
    the acer-wmi hwmon device that exposes fan tachs + chassis temps.
    """
    for h in sorted(glob.glob("/sys/class/hwmon/hwmon*")):
        try:
            if Path(h, "name").read_text().strip() == "acer":
                return Path(h)
        except OSError:
            pass
    return None


def _find_battery() -> Path | None:
    for b in sorted(glob.glob("/sys/class/power_supply/BAT*")):
        return Path(b)
    return None


def _profile_choices() -> list[str]:
    raw = _read_first_line(PLATFORM_PROFILE_CHOICES)
    return raw.split() if raw else []


def _resolve_profile(name: str) -> str:
    """Map a user-supplied name to a real platform_profile choice.

    If the name is already one of the choices, pass it through. If
    it's a known alias and the alias' target exists in the choices,
    use that. Otherwise leave it alone and let the kernel reject it
    with a clear error.
    """
    choices = _profile_choices()
    if name in choices:
        return name
    aliased = PROFILE_ALIASES.get(name)
    if aliased and (not choices or aliased in choices):
        return aliased
    return name


# ---------------------------- per-source power policy (AC vs battery)
#
# PredatorSense on Windows keeps a separate power profile for "plugged
# in" vs "on battery". We mirror that with a policy file at
# ~/.config/venator/power-policy.json:
#
#     { "ac": "performance", "battery": "balanced" }
#
# Values are *raw* platform_profile names (low-power / quiet / balanced /
# balanced-performance / performance). `power-policy apply` reads the
# current power source and writes the matching slot. The restore service
# (`profile load default`) calls apply at login, so the right profile
# comes back after a reboot.
#
# Battery safety: on battery we only allow the three low-heat profiles
# unless the user explicitly opts into the high-power ones (which spin
# the fans + drain the pack fast). The raw names that map to
# PredatorSense's "Performance"/"Turbo" are gated behind --advanced.

POWER_POLICY_PATH = _real_home() / ".config" / "venator" / "power-policy.json"

# Raw platform_profile names considered safe to run on battery.
BATTERY_SAFE_PROFILES = {"low-power", "quiet", "balanced"}

# First-use defaults: a fresh install with no policy file behaves as
# "balanced on AC, quiet on battery" — sane out of the box, and what
# the power-watch daemon applies before the user configures anything.
POWER_POLICY_DEFAULTS = {"ac": "balanced", "battery": "quiet"}


def _read_power_policy() -> dict:
    if not POWER_POLICY_PATH.exists():
        return dict(POWER_POLICY_DEFAULTS)
    try:
        d = json.loads(POWER_POLICY_PATH.read_text())
        if not isinstance(d, dict):
            return dict(POWER_POLICY_DEFAULTS)
        d.setdefault("ac", POWER_POLICY_DEFAULTS["ac"])
        d.setdefault("battery", POWER_POLICY_DEFAULTS["battery"])
        return d
    except (OSError, json.JSONDecodeError):
        return dict(POWER_POLICY_DEFAULTS)


def _write_power_policy(d: dict) -> None:
    POWER_POLICY_PATH.parent.mkdir(parents=True, exist_ok=True)
    _chown_to_invoker(POWER_POLICY_PATH.parent)
    POWER_POLICY_PATH.write_text(json.dumps(d, indent=2, sort_keys=True))
    _chown_to_invoker(POWER_POLICY_PATH)


def _on_ac_power() -> bool | None:
    """True if a mains adapter reports online, False if one exists and
    reads offline, None if no adapter is present (e.g. a desktop, or the
    adapter doesn't expose `online`).
    """
    found = False
    for d in sorted(glob.glob("/sys/class/power_supply/*")):
        dp = Path(d)
        try:
            if (dp / "type").read_text().strip() == "Battery":
                continue
        except OSError:
            continue
        online = dp / "online"
        if not online.exists():
            continue
        try:
            val = online.read_text().strip()
        except OSError:
            continue
        found = True
        if val == "1":
            return True
    return False if found else None


def _profile_is_battery_safe(raw: str) -> bool:
    return raw in BATTERY_SAFE_PROFILES


def _apply_power_profile(target: str) -> str | None:
    """Write `target` to platform_profile and run the auto-RGB hook.
    Returns the resulting profile string, or None on failure (message
    already written to stderr). Used by the policy + restore paths;
    cmd_power keeps its own richer messaging.
    """
    if not PLATFORM_PROFILE.exists():
        sys.stderr.write("power-policy: no platform_profile (is acer-wmi loaded?)\n")
        return None
    try:
        PLATFORM_PROFILE.write_text(target)
    except PermissionError:
        sys.stderr.write(f"power-policy: permission denied writing {PLATFORM_PROFILE}\n")
        return None
    except OSError as e:
        sys.stderr.write(f"power-policy: kernel rejected {target!r}: {e}\n")
        return None
    new = _read_first_line(PLATFORM_PROFILE) or "?"
    _maybe_apply_power_rgb(new)
    return new


def _remember_power_profile(raw: str) -> None:
    """Persist `raw` into the policy slot for the *current* power source
    so a plain `power <profile>` is restored at next login. On battery
    we only remember battery-safe profiles — we don't want a one-off
    Turbo burst to become the thing we auto-restore every boot.
    """
    on_ac = _on_ac_power()
    slot = "battery" if on_ac is False else "ac"
    if slot == "battery" and not _profile_is_battery_safe(raw):
        return
    pol = _read_power_policy()
    if pol.get(slot) == raw:
        return
    pol[slot] = raw
    _write_power_policy(pol)


def _apply_power_policy(*, verbose: bool = True) -> None:
    """Apply the stored profile for the current power source. No-op if
    nothing is stored for that source. Called by the restore path.
    """
    pol = _read_power_policy()
    on_ac = _on_ac_power()
    # Unknown source (desktop / no adapter) → fall back to the AC slot.
    slot = "battery" if on_ac is False else "ac"
    target = pol.get(slot)
    if not target:
        if verbose:
            sys.stderr.write(f"power-policy: no profile stored for {slot}; skipping\n")
        return
    new = _apply_power_profile(target)
    if new and verbose:
        src = "AC" if slot == "ac" else "battery"
        sys.stderr.write(f"power-policy: on {src} -> {new}\n")


def cmd_power_policy(args: argparse.Namespace) -> None:
    """Show the AC/battery power policy + what would be applied now."""
    pol = _read_power_policy()
    on_ac = _on_ac_power()
    src = ("AC" if on_ac is True else
           "battery" if on_ac is False else
           "unknown (no adapter detected)")
    ac_p  = pol.get("ac")  or "(unset)"
    bat_p = pol.get("battery") or "(unset)"
    print(f"power source : {src}")
    print(f"on AC        : {ac_p}")
    print(f"on battery   : {bat_p}")
    active_slot = "battery" if on_ac is False else "ac"
    active = pol.get(active_slot)
    if active:
        print(f"would apply  : {active}  (for current source)")
    print()
    print("set with:")
    print("  venator power-policy ac <profile>")
    print("  venator power-policy battery <profile> [--advanced]")
    print("  venator power-policy apply        # apply now / used at login")
    print()
    print("battery-safe profiles: eco (low-power), quiet, balanced")
    print("performance/turbo on battery need --advanced (degrades battery).")


def cmd_power_policy_set(args: argparse.Namespace) -> None:
    """Set the policy for one slot (args.slot is 'ac' or 'battery')."""
    slot = args.slot
    raw = _resolve_profile(args.profile)
    if slot == "battery" and not _profile_is_battery_safe(raw):
        if not getattr(args, "advanced", False):
            die(f"{args.profile!r} (resolves to {raw!r}) is not allowed on "
                f"battery.\nBattery-safe profiles: eco, quiet, balanced.\n"
                f"Pass --advanced to force performance/turbo on battery — "
                f"this runs the fans hard and degrades battery health.")
        sys.stderr.write(
            "WARNING: setting a high-power profile on battery. This drains\n"
            "         the pack fast and accelerates wear. Proceeding because\n"
            "         --advanced was given.\n")
    pol = _read_power_policy()
    pol[slot] = raw
    _write_power_policy(pol)
    print(f"power-policy {slot}: {raw}")
    # Apply immediately if the current source matches this slot.
    on_ac = _on_ac_power()
    cur_slot = "battery" if on_ac is False else "ac"
    if cur_slot == slot:
        new = _apply_power_profile(raw)
        if new:
            print(f"applied now ({slot} is the current source): {new}")


def cmd_power_policy_apply(args: argparse.Namespace) -> None:
    _apply_power_policy(verbose=True)


def cmd_power_policy_clear(args: argparse.Namespace) -> None:
    if POWER_POLICY_PATH.exists():
        POWER_POLICY_PATH.unlink()
        print("power-policy cleared")
    else:
        print("no power-policy set")


def cmd_power_watch(args: argparse.Namespace) -> None:
    """Long-running daemon: watch the AC adapter and re-apply the policy
    profile whenever the laptop is plugged in / unplugged. This is what
    makes the profile change in real time on plug/unplug.

    Run by the venator-powerwatch.service user unit. Polls the
    power_supply `online` files (dependency-free, cheap — one tiny read
    per tick). On a transition it waits `--settle` seconds so our write
    lands AFTER any still-running daemon (PPD/tuned) re-applies its own
    choice on the same event, then applies our policy.
    """
    if not PLATFORM_PROFILE.exists():
        die("no platform_profile (acer-wmi loaded?); nothing to watch")

    interval = max(0.5, float(getattr(args, "interval", 2.0)))
    settle   = max(0.0, float(getattr(args, "settle", 1.0)))

    # One-time heads-up if a competing daemon is active — it'll fight us
    # on every event; the settle delay helps us win, but masking is the
    # real fix.
    active = _active_power_managers()
    if active:
        names = ", ".join(label for label, _ in active)
        sys.stderr.write(
            f"power-watch: {names} is active and may briefly override the\n"
            f"             profile on AC change. For rock-solid switching run:\n"
            f"             venator power --detach-ppd\n")

    sys.stderr.write(
        f"power-watch: started (interval={interval}s, settle={settle}s)\n")

    # Apply once at startup so state is correct even if we missed an
    # event while not running.
    _apply_power_policy(verbose=True)
    last = _on_ac_power()

    while True:
        time.sleep(interval)
        cur = _on_ac_power()
        if cur == last:
            continue
        # Edge detected.
        src = "AC" if cur is True else "battery" if cur is False else "unknown"
        sys.stderr.write(f"power-watch: power source changed -> {src}\n")
        last = cur
        if settle:
            time.sleep(settle)
            # Re-read in case it bounced back during the settle window.
            cur = _on_ac_power()
            last = cur
        _apply_power_policy(verbose=True)


def cmd_power(args: argparse.Namespace) -> None:
    if not PLATFORM_PROFILE.exists():
        die("no /sys/firmware/acpi/platform_profile on this kernel; need acer-wmi loaded")

    # PPD detach/attach flags can run with or without a profile arg. Run
    # them first so a combined call like `power turbo --detach-ppd` masks
    # PPD before we try to set a mode it doesn't know about.
    if args.detach_ppd:
        _do_detach_ppd()
    if args.attach_ppd:
        _do_attach_ppd()

    current = _read_first_line(PLATFORM_PROFILE) or "?"
    choices = _profile_choices()
    if args.name is None:
        if args.detach_ppd or args.attach_ppd:
            return
        print(f"current: {current}")
        if choices:
            print(f"choices: {' '.join(choices)}")
        print()
        print("aliases:")
        seen = set()
        for alias, target in PROFILE_ALIASES.items():
            if target in choices and (alias, target) not in seen:
                print(f"  {alias:12s} -> {target}")
                seen.add((alias, target))
        print()
        # Report every power-management daemon we know about, not just
        # PPD — tuned / auto-cpufreq / etc. fight us the same way.
        active = _active_power_managers()
        masked = _masked_power_managers()
        if active:
            print("active power managers (these revert profile on AC change):")
            for label, _unit in active:
                print(f"  {label}")
            print("  detach them with: venator power --detach-ppd")
        elif masked:
            print("power managers: all masked — venator owns "
                  "platform_profile")
            print("  re-attach with: venator power --attach-ppd")
        else:
            print("power managers: none active — venator owns "
                  "platform_profile")
        return
    target = _resolve_profile(args.name)
    try:
        PLATFORM_PROFILE.write_text(target)
    except PermissionError:
        die(f"permission denied writing {PLATFORM_PROFILE} (try sudo, "
            "or check the venator udev rule applies)")
    except OSError as e:
        if "Invalid argument" in str(e) or e.errno == 22:
            die(f"kernel rejected {target!r}; valid choices: {' '.join(choices)}")
        die(f"failed to set power profile: {e}")
    new = _read_first_line(PLATFORM_PROFILE) or "?"
    print(f"power profile: {current} -> {new}")
    if new != target:
        print(f"  (requested {target!r} but kernel reports {new!r})", file=sys.stderr)
    active = _active_power_managers()
    if active:
        names = ", ".join(label for label, _ in active)
        print(f"note: {names} active. It may revert this on the next AC")
        print("      plug/unplug. Mask it with: venator power --detach-ppd")
    # Auto-apply linked RGB scheme if configured for this profile.
    _maybe_apply_power_rgb(new)
    # Remember this choice for the current power source so it's restored
    # at next login (battery-safe profiles only; see _remember_power_profile).
    _remember_power_profile(new)


# ---------------------------- auto-link RGB to power profile
#
# Stored at ~/.config/venator/power-rgb.json. Shape:
#     { "enabled": true,
#       "mappings": { "low-power": "#0000ff", ..., "performance": "#ff0000" } }
# The dict key is the *raw* platform_profile name (low-power / quiet /
# balanced / balanced-performance / performance) — same as what
# /sys/firmware/acpi/platform_profile_choices reports. Lookup happens
# AFTER the profile write so a bad colour can't block the profile
# change.

POWER_RGB_PATH = _real_home() / ".config" / "venator" / "power-rgb.json"


def _read_power_rgb() -> dict:
    if not POWER_RGB_PATH.exists():
        return {"enabled": False, "mappings": {}}
    try:
        d = json.loads(POWER_RGB_PATH.read_text())
        if not isinstance(d, dict):
            return {"enabled": False, "mappings": {}}
        d.setdefault("enabled",  False)
        d.setdefault("mappings", {})
        return d
    except (OSError, json.JSONDecodeError):
        return {"enabled": False, "mappings": {}}


def _write_power_rgb(d: dict) -> None:
    POWER_RGB_PATH.parent.mkdir(parents=True, exist_ok=True)
    # Chown the dir if we got root via sudo.
    _chown_to_invoker(POWER_RGB_PATH.parent)
    POWER_RGB_PATH.write_text(json.dumps(d, indent=2, sort_keys=True))
    _chown_to_invoker(POWER_RGB_PATH)


def _maybe_apply_power_rgb(profile: str) -> None:
    """Look up `profile` in the power-rgb mapping and apply the colour
    via rgb static. Errors warn instead of dying — the profile change
    already succeeded by the time we're called, so we don't want a
    mis-configured colour to fail the whole command.

    Verbose: prints why the lookup was skipped so users debugging
    `power-rgb` aren't left guessing.
    """
    cfg = _read_power_rgb()
    if not cfg.get("enabled"):
        if cfg.get("mappings"):
            print(f"  auto-RGB: disabled (mappings exist; "
                  f"`venator power-rgb enable` to turn on)")
        return
    mappings = cfg.get("mappings", {})
    colour = mappings.get(profile)
    if not colour:
        # Helpful debug: tell the user the lookup happened but missed.
        if mappings:
            print(f"  auto-RGB: no mapping for profile {profile!r} "
                  f"(set one with `power-rgb set {profile} #RRGGBB`)")
        return
    norm_colour = colour if colour.startswith("#") else "#" + colour
    print(f"  auto-RGB: {profile} -> {norm_colour}")
    # Reuse the same path the rgb static command takes, including the
    # auto-save of the 'default' profile so the colour persists across
    # reboots.
    ns = argparse.Namespace(color=norm_colour, brightness=None,
                            timeout=DEFAULT_TIMEOUT_S)
    try:
        cmd_rgb_static(ns)
    except SystemExit as e:
        # die() raises SystemExit(1). Re-print the reason so the user
        # sees what went wrong (typically "device not found" if the
        # kernel module isn't loaded, or "permission denied" outside
        # the venator group).
        print(f"  auto-RGB: rgb_static failed (exit {e.code}). Is the "
              f"venator kmod loaded + are you in the venator "
              f"group?", file=sys.stderr)
    except Exception as e:
        print(f"  auto-RGB: rgb_static raised: {e}", file=sys.stderr)


def cmd_power_rgb_set(args: argparse.Namespace) -> None:
    profile = args.profile
    colour  = args.color
    parse_rgb(colour)         # parse_rgb -> die() on invalid; no extra check needed
    # Allow either the friendly alias OR the raw name; canonicalise to
    # the raw platform_profile name so the lookup later matches.
    raw = PROFILE_ALIASES.get(profile, profile)
    cfg = _read_power_rgb()
    cfg["mappings"][raw] = colour if colour.startswith("#") else "#" + colour
    # Setting a mapping implies the user wants it applied. Always
    # enable on `set`; `venator power-rgb disable` is the
    # explicit opt-out.
    was_enabled = cfg.get("enabled", False)
    cfg["enabled"] = True
    _write_power_rgb(cfg)
    print(f"power-rgb: {raw} -> {cfg['mappings'][raw]}  (enabled)")
    if not was_enabled:
        print("  (auto-apply turned on; disable with: venator power-rgb disable)")


def cmd_power_rgb_unset(args: argparse.Namespace) -> None:
    raw = PROFILE_ALIASES.get(args.profile, args.profile)
    cfg = _read_power_rgb()
    if raw in cfg["mappings"]:
        del cfg["mappings"][raw]
        _write_power_rgb(cfg)
        print(f"power-rgb: removed mapping for {raw}")
    else:
        print(f"power-rgb: no mapping for {raw}")


def cmd_power_rgb_list(_: argparse.Namespace) -> None:
    cfg = _read_power_rgb()
    state = "[on]" if cfg.get("enabled") else "[off]"
    print(f"power-rgb {state}  (config: {POWER_RGB_PATH})")
    if not cfg["mappings"]:
        print("  (no mappings)")
        print("  add one with: venator power-rgb set <profile> <#RRGGBB>")
        return
    for k, v in sorted(cfg["mappings"].items()):
        pretty = next((alias for alias, target
                       in PROFILE_ALIASES.items() if target == k),
                      k)
        print(f"  {k:24s} -> {v}   ({pretty})")


def cmd_power_rgb_toggle(args: argparse.Namespace) -> None:
    cfg = _read_power_rgb()
    if args.cmd_action == "enable":
        cfg["enabled"] = True
    elif args.cmd_action == "disable":
        cfg["enabled"] = False
    _write_power_rgb(cfg)
    print(f"power-rgb: {'enabled' if cfg['enabled'] else 'disabled'}")


def cmd_power_rgb_apply(_: argparse.Namespace) -> None:
    """Force-apply the colour mapping for the current platform profile,
    regardless of whether the global enable flag is set. Useful for
    testing a fresh mapping without having to flip profiles."""
    cur = _read_first_line(PLATFORM_PROFILE) or "?"
    cfg = _read_power_rgb()
    mappings = cfg.get("mappings", {})
    colour = mappings.get(cur)
    if not colour:
        die(f"no power-rgb mapping for current profile {cur!r}. "
            f"Set one with: venator power-rgb set {cur} '#RRGGBB'")
    norm_colour = colour if colour.startswith("#") else "#" + colour
    print(f"applying power-rgb for {cur}: {norm_colour}")
    ns = argparse.Namespace(color=norm_colour, brightness=None,
                            timeout=DEFAULT_TIMEOUT_S)
    cmd_rgb_static(ns)


PPD_UNIT = "power-profiles-daemon.service"

# Other daemons that also drive /sys/firmware/acpi/platform_profile (or
# otherwise fight us for CPU/thermal control). On a plug/unplug event
# they re-apply their own choice, which is exactly what stomps on our
# per-source policy. We detect every one that's active so the user
# isn't left wondering why their profile keeps reverting — PPD is just
# the most common; tuned ships by default on several distros now, and
# the others show up on System76 / laptop-optimised setups.
#
# (label, systemd unit). Order = the order we'd mask them in.
POWER_MANAGER_UNITS = [
    ("power-profiles-daemon", "power-profiles-daemon.service"),
    ("tuned",                 "tuned.service"),
    ("auto-cpufreq",          "auto-cpufreq.service"),
    ("system76-power",        "system76-power.service"),
    ("tlp",                   "tlp.service"),
]


def _systemctl(*args: str, sudo: bool = False) -> subprocess.CompletedProcess:
    cmd = ["systemctl", *args]
    if sudo and os.geteuid() != 0:
        cmd = ["sudo", *cmd]
    return subprocess.run(cmd, capture_output=True, text=True)


def _unit_is_active(unit: str) -> bool:
    return _systemctl("is-active", "--quiet", unit).returncode == 0


def _unit_is_masked(unit: str) -> bool:
    return _systemctl("is-enabled", unit).stdout.strip() == "masked"


def _active_power_managers() -> list[tuple[str, str]]:
    """Return [(label, unit), …] for every known power-management daemon
    that is currently active. Empty list = we own platform_profile.
    """
    return [(label, unit) for label, unit in POWER_MANAGER_UNITS
            if _unit_is_active(unit)]


def _masked_power_managers() -> list[tuple[str, str]]:
    return [(label, unit) for label, unit in POWER_MANAGER_UNITS
            if _unit_is_masked(unit)]


# Back-compat shims: the original code only knew about PPD.
def _ppd_is_active() -> bool:
    return _unit_is_active(PPD_UNIT)


def _ppd_is_masked() -> bool:
    return _unit_is_masked(PPD_UNIT)


def _do_detach_ppd() -> None:
    """Mask every active power-management daemon so none of them fight
    our writes.

    These daemons own /sys/firmware/acpi/platform_profile and typically
    expose only 3 coarse modes. Any direct write we make (e.g.
    balanced-performance, or performance for true turbo) survives until
    the next AC plug/unplug event — then the daemon re-applies its own
    choice. Masking them stops that and lets venator + the
    power-watch daemon own the profile.
    """
    active = _active_power_managers()
    if not active:
        # Nothing active. Mention any that exist-but-inactive for clarity.
        print("no active power-management daemon found "
              "(power-profiles-daemon / tuned / auto-cpufreq / …).")
        print("venator already owns platform_profile.")
        return
    for label, unit in active:
        if _unit_is_masked(unit):
            print(f"{label}: already masked")
            continue
        r = _systemctl("mask", "--now", unit, sudo=True)
        if r.returncode != 0:
            sys.stderr.write(f"warning: masking {label} ({unit}) failed: "
                             f"{r.stderr.strip() or r.stdout.strip()}\n")
            continue
        print(f"{label}: masked.")
    print("venator now owns platform_profile.")
    print("  re-attach with: venator power --attach-ppd")


def _do_attach_ppd() -> None:
    """Undo --detach-ppd: unmask + start every power manager we masked."""
    masked = _masked_power_managers()
    if not masked:
        print("no power-management daemon is masked; nothing to do")
        return
    for label, unit in masked:
        r = _systemctl("unmask", unit, sudo=True)
        if r.returncode != 0:
            sys.stderr.write(f"warning: unmasking {label} ({unit}) failed: "
                             f"{r.stderr.strip() or r.stdout.strip()}\n")
            continue
        _systemctl("start", unit, sudo=True)
        print(f"{label}: unmasked + started.")


VENATOR_BATTERY_DIR = Path("/sys/class/venator/battery0")
VENATOR_GAMING_DIR = Path("/sys/class/venator/gaming0")
VENATOR_LIGHTBAR_DIR = Path("/sys/class/venator/lightbar0")


def _end_threshold_path() -> Path | None:
    """Find a writable charge-limit sysfs path.

    Prefer our own kernel module's /sys/class/venator/battery0/
    (PH16-71 isn't in mainline acer_wmi_battery's quirk list). Fall
    back to /sys/class/power_supply/BAT*/charge_control_end_threshold
    for boards that ARE in the mainline quirk list (so the same CLI
    works on other Acers).
    """
    p = VENATOR_BATTERY_DIR / "charge_control_end_threshold"
    if p.exists():
        return p
    bat = _find_battery()
    if bat is not None:
        p = bat / "charge_control_end_threshold"
        if p.exists():
            return p
    return None


def cmd_battery_info(_: argparse.Namespace) -> None:
    bat = _find_battery()
    if bat is None:
        die("no /sys/class/power_supply/BAT* on this box")
    print(f"device: {bat}")
    for f in ("manufacturer", "model_name", "technology", "status",
              "capacity", "energy_full", "energy_full_design",
              "voltage_now", "current_now",
              "charge_control_start_threshold",
              "charge_control_end_threshold",
              "charge_behaviour", "charge_type"):
        p = bat / f
        if p.exists():
            print(f"  {f:34s} {_read_first_line(p)}")
    # Our own kernel-module-exposed bits, if loaded.
    if VENATOR_BATTERY_DIR.exists():
        print()
        print(f"venator: {VENATOR_BATTERY_DIR}")
        for f in ("charge_control_end_threshold",
                  "health_mode", "calibration_mode"):
            p = VENATOR_BATTERY_DIR / f
            if p.exists():
                print(f"  {f:34s} {_read_first_line(p)}")
    elif not (bat / "charge_control_end_threshold").exists():
        print()
        print("  NOTE: no charge-control sysfs found. Load the kernel half:")
        print("    sudo modprobe venator   # or `sudo make install`")
        print("  Then re-run `venator battery info`.")


def cmd_battery_limit(args: argparse.Namespace) -> None:
    end_p = _end_threshold_path()
    if args.value is None:
        if end_p is None:
            die("no charge-control sysfs present; reload venator")
        print(_read_first_line(end_p))
        return
    if end_p is None:
        die("no charge-control sysfs present; reload venator and retry")
    v = args.value.strip().lower()
    if v in ("on", "enable", "enabled"):
        target = 80         # PH16-71 firmware-fixed cap
    elif v in ("off", "none", "disable", "disabled", "100"):
        target = 100
    else:
        try:
            target = int(v)
        except ValueError:
            die(f"expected 'on' / 'off' / percent (1..100), got {args.value!r}")
        if not 1 <= target <= 100:
            die("limit must be 1..100, 'on', or 'off'")
    try:
        end_p.write_text(str(target))
    except PermissionError:
        die(f"permission denied writing {end_p} (try sudo, or check the "
            "venator group + udev rule)")
    except OSError as e:
        if e.errno in (22, 34):  # EINVAL or ERANGE
            die(f"kernel rejected {target}; PH16-71 only supports 80 (cap) "
                "or 100 (off)")
        die(f"failed to set charge limit: {e}")
    actual = _read_first_line(end_p)
    print(f"battery charge limit: {actual}%")
    if str(target) != actual:
        print(f"  (requested {target}%; firmware applied {actual}% — "
              "PH16-71 only offers fixed 80% cap)", file=sys.stderr)


