def _unified_anim_dirs() -> list[Path]:
    """Same lookup order as _unified_dirs but for animations."""
    out: list[Path] = []
    cfg = _real_home() / ".config" / "venator" / "animations" / "unified"
    if cfg.is_dir():
        out.append(cfg)
    here = Path(__file__).resolve().parent
    for cand in (here / "animations" / "unified",
                 Path("/usr/local/share/venator/animations/unified"),
                 Path("/usr/share/venator/animations/unified")):
        if cand.is_dir():
            out.append(cand)
    return out


def _find_unified_anim(name_or_path: str) -> Path:
    p = Path(name_or_path)
    if p.suffix == ".py" and p.is_file():
        return p
    name = name_or_path if name_or_path.endswith(".py") else name_or_path + ".py"
    for d in _unified_anim_dirs():
        cand = d / name
        if cand.is_file():
            return cand
    die(f"unified animation {name_or_path!r} not found in: "
        + ", ".join(str(d) for d in _unified_anim_dirs()))


def _list_unified_anims() -> dict[str, Path]:
    out: dict[str, Path] = {}
    for d in _unified_anim_dirs():
        for f in sorted(d.glob("*.py")):
            out.setdefault(f.stem, f)
    return out


def _apply_unified_step(state: dict) -> None:
    """Push one synchronized frame to keyboard + lightbar.

    Goes via the existing rgb/lightbar code paths so brightness/mode
    handling stays canonical. Errors on one half don't kill the loop.
    """
    kb = state.get("keyboard")
    if isinstance(kb, dict):
        mode = (kb.get("mode") or "static").strip().lower()
        color = (kb.get("color") or "").lstrip("#")
        bright = kb.get("brightness")
        try:
            dev = find_device()
        except SystemExit:
            dev = None
        if dev is not None:
            try:
                if mode in ("off", ""):
                    write_text_attr(dev, "mode", "off")
                else:
                    write_text_attr(dev, "mode", mode)
                    if color:
                        write_text_attr(dev, "color", color)
                    if bright is not None:
                        write_text_attr(dev, "brightness", str(int(bright)))
                commit(dev)
            except OSError as e:
                sys.stderr.write(f"keyboard step failed: {e}\n")

    lb = state.get("lightbar")
    if isinstance(lb, dict) and VENATOR_LIGHTBAR_DIR.exists():
        mode_name = (lb.get("mode") or "static").strip().lower()
        if mode_name in LB_MODE_IDS:
            mode_id = LB_MODE_IDS[mode_name]
            try:
                bright = int(lb.get("brightness", 100))
            except (TypeError, ValueError):
                bright = 100
            try:
                speed = int(lb.get("speed", 5))
            except (TypeError, ValueError):
                speed = 5
            hex_c = (lb.get("color") or "ff0000").lstrip("#")
            try:
                r = int(hex_c[0:2], 16); g = int(hex_c[2:4], 16); b = int(hex_c[4:6], 16)
            except (ValueError, IndexError):
                r, g, b = 0xff, 0, 0
            try:
                (VENATOR_LIGHTBAR_DIR / "set").write_text(
                    f"{mode_id} {bright} {speed} {r} {g} {b}")
            except OSError as e:
                sys.stderr.write(f"lightbar step failed: {e}\n")


def cmd_unified_anim(args: argparse.Namespace) -> None:
    """Run a synchronized keyboard + lightbar animation in the
    foreground. Ctrl-C stops cleanly.
    """
    import importlib.util
    import signal as _signal

    if args.name == "list":
        anims = _list_unified_anims()
        if not anims:
            print("no unified animations found")
            return
        for name, p in sorted(anims.items()):
            spec = importlib.util.spec_from_file_location(name, p)
            mod = importlib.util.module_from_spec(spec)
            try:
                spec.loader.exec_module(mod)
                desc = getattr(mod, "DESCRIPTION", "")
            except Exception:
                desc = "(failed to import)"
            print(f"  {name:18s}  {desc}")
        return

    path = _find_unified_anim(args.name)
    spec = importlib.util.spec_from_file_location(path.stem, path)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    if not hasattr(mod, "step"):
        die(f"{path.name} doesn't define step(t)")
    fps = max(1, int(getattr(mod, "FPS", 6)))
    period = 1.0 / fps

    stop = {"v": False}
    def _sigterm(_a, _b): stop["v"] = True
    _signal.signal(_signal.SIGINT, _sigterm)
    _signal.signal(_signal.SIGTERM, _sigterm)

    print(f"running unified animation '{path.stem}' @ {fps} FPS — Ctrl-C to stop")
    start = time.time()
    deadline = (start + args.timeout) if args.timeout > 0 else None
    while not stop["v"]:
        t = time.time() - start
        if deadline and time.time() >= deadline:
            break
        try:
            state = mod.step(t)
        except Exception as e:
            sys.stderr.write(f"step failed: {e}\n")
            break
        if isinstance(state, dict):
            _apply_unified_step(state)
        time.sleep(period)
    print("animation stopped, last frame held")


