def cmd_profile_save(args: argparse.Namespace) -> None:
    dev = find_device()
    snapshot: dict[str, object] = {
        k: read_text_attr(dev, k) for k in PROFILE_KEYS
    }
    frame_path = dev / "frame"
    if frame_path.exists():
        try:
            frame = frame_path.read_bytes()
            if len(frame) == PERKEY_BYTES:
                snapshot["frame_hex"] = frame.hex()
        except OSError:
            pass
    # Create + chown the directory tree to the invoking user (handles sudo).
    parts = []
    p = PROFILE_DIR
    while not p.exists() and p != p.parent:
        parts.append(p); p = p.parent
    PROFILE_DIR.mkdir(parents=True, exist_ok=True)
    for created in reversed(parts):
        _chown_to_invoker(created)
    out = PROFILE_DIR / f"{args.name}.json"
    out.write_text(json.dumps(snapshot, indent=2, sort_keys=True))
    _chown_to_invoker(out)
    print(f"saved {out}")


def cmd_profile_load(args: argparse.Namespace) -> None:
    src = PROFILE_DIR / f"{args.name}.json"
    if not src.exists():
        die(f"profile not found: {src}")
    snap = json.loads(src.read_text())

    # Power profile policy is global, not tied to a single RGB profile.
    # The restore service loads the 'default' profile at login, so
    # piggyback the AC/battery power-profile restore here. Best-effort:
    # a failure (no acer-wmi, no permission) must not block the RGB
    # restore below.
    if args.name == DEFAULT_PROFILE_NAME:
        try:
            _apply_power_policy(verbose=True)
        except Exception as e:
            sys.stderr.write(f"power-policy apply skipped: {e}\n")

    # Restore lightbar FIRST, independently of the keyboard half. The
    # restore service runs at session start and the keyboard may not
    # have enumerated by then (USB warm-up), but the WMBH lightbar
    # path is bound to the WMI device which IS up. Doing lightbar
    # first guarantees the bar comes back even if the keyboard half
    # bails below.
    _restore_lightbar_from_snap(snap)

    try:
        dev = find_device()
    except SystemExit:
        # No keyboard found — common if the venator module is
        # mid-rebuild, the USB device is still warming up, or this is
        # a desktop without the gaming keyboard. Lightbar already
        # restored above; that's all we can do.
        sys.stderr.write(
            "profile load: no keyboard sysfs (yet); "
            "lightbar half restored, keyboard half skipped\n")
        return
    stop_background()

    try:
        timeout = int(snap.get("timeout", DEFAULT_TIMEOUT_S))
    except (TypeError, ValueError):
        timeout = DEFAULT_TIMEOUT_S
    if not (0 <= timeout <= TIMEOUT_MAX_S):
        timeout = DEFAULT_TIMEOUT_S

    # Animation-typed profile: respawn the animator.
    anim = snap.get("animation_name")
    if anim:
        # Brightness is stored as a sysfs string ("200"); coerce to int.
        try:
            b = int(snap.get("brightness", "")) if snap.get("brightness") else None
        except ValueError:
            b = None
        # First push the static fields too so brightness etc. land before
        # the animator's first frame.
        if b is not None:
            write_text_attr(dev, "brightness", str(b))
        start_animator(anim, b, timeout)
        print(f"resumed animation '{anim}' (timeout={timeout}s)")
        return

    # Static-typed profile: restore the frame + mode + brightness.
    if "frame_hex" in snap:
        try:
            write_bin_attr(dev, "frame", bytes.fromhex(snap["frame_hex"]))
        except ValueError:
            pass
    for k in PROFILE_KEYS:
        v = snap.get(k)
        if v:
            try:
                write_text_attr(dev, k, str(v))
            except (PermissionError, OSError) as e:
                sys.stderr.write(f"profile load: skip {k}: {e}\n")
    try:
        commit(dev)
    except (PermissionError, OSError) as e:
        sys.stderr.write(f"profile load: commit failed: {e}\n")
    # Spawn a keepalive worker honouring the saved timeout. With
    # timeout=0 it runs forever; otherwise it exits + turns off LEDs at
    # the deadline.
    if snap.get("mode") not in (None, "off"):
        start_keepalive(timeout)


def _restore_lightbar_from_snap(snap: dict) -> None:
    """Replay the saved lightbar state into the kernel.

    Retries on PermissionError because the systemd restore service can
    fire faster than udev applies the chgrp+chmod from
    70-venator.rules. Half a second of retry is enough.
    """
    lb = snap.get("lightbar")
    if not isinstance(lb, dict):
        return
    if not VENATOR_LIGHTBAR_DIR.exists():
        sys.stderr.write("lightbar restore: /sys/class/venator/lightbar0 not present "
                         "(venator not loaded yet?); skipping\n")
        return
    mode_name = (lb.get("mode") or "").strip().lower()
    if mode_name not in LB_MODE_IDS:
        sys.stderr.write(f"lightbar restore: unknown saved mode {mode_name!r}; skipping\n")
        return
    mode_id = LB_MODE_IDS[mode_name]
    try:
        bright = int(lb.get("brightness") or 100)
    except (TypeError, ValueError):
        bright = 100
    try:
        speed = int(lb.get("speed") or 5)
    except (TypeError, ValueError):
        speed = 5
    hex_color = (lb.get("color") or "ff0000").strip().lstrip("#")
    try:
        r = int(hex_color[0:2], 16)
        g = int(hex_color[2:4], 16)
        b = int(hex_color[4:6], 16)
    except (ValueError, IndexError):
        r, g, b = 0xff, 0, 0

    payload = f"{mode_id} {bright} {speed} {r} {g} {b}"
    target = VENATOR_LIGHTBAR_DIR / "set"
    # Retry loop to ride out the udev → chgrp race on cold boot.
    last_err = None
    for attempt in range(10):
        try:
            target.write_text(payload)
            sys.stderr.write(f"lightbar restore: applied {payload}\n")
            return
        except PermissionError as e:
            last_err = e
            time.sleep(0.1)
        except OSError as e:
            last_err = e
            break
    sys.stderr.write(f"lightbar restore: failed after retries: {last_err}\n")


