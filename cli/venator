# ---- lightbar animations ----------------------------------------------------

def _lb_animation_dirs() -> list[Path]:
    """Search order:
       1. ~/.config/venator/animations/lightbar/   (user overrides)
       2. Source-checkout sibling (cli/ and tui/ next to each other)
       3. /usr/local/share/venator/animations/lightbar/
       4. /usr/share/venator/animations/lightbar/

    Note: the Makefile installs `cli/animations/*` to
    `$SHAREDIR/animations/*` (no `cli/` segment), so the system paths
    below intentionally drop that segment too.
    """
    out: list[Path] = []
    cfg = _real_home() / ".config" / "venator" / "animations" / "lightbar"
    if cfg.is_dir():
        out.append(cfg)
    here = Path(__file__).resolve().parent
    for cand in (here / "animations" / "lightbar",
                 Path("/usr/local/share/venator/animations/lightbar"),
                 Path("/usr/share/venator/animations/lightbar")):
        if cand.is_dir():
            out.append(cand)
    return out


def _find_lb_animation(name_or_path: str) -> Path:
    p = Path(name_or_path)
    if p.suffix == ".py" and p.is_file():
        return p
    name = name_or_path
    if not name.endswith(".py"):
        name = name + ".py"
    for d in _lb_animation_dirs():
        cand = d / name
        if cand.is_file():
            return cand
    die(f"animation {name_or_path!r} not found in: "
        + ", ".join(str(d) for d in _lb_animation_dirs()))


def _list_lb_animations() -> dict[str, Path]:
    out: dict[str, Path] = {}
    for d in _lb_animation_dirs():
        for f in sorted(d.glob("*.py")):
            out.setdefault(f.stem, f)
    return out


def _apply_lb_step(state: dict) -> None:
    """Push one frame of animation state to the kernel."""
    # Order matters: mode + speed/brightness first (cheap single
    # WMI call), then per-zone overrides.
    if any(k in state for k in ("mode", "color", "brightness", "speed")):
        args = ["lightbar", "set"]
        if "mode" in state:
            args += ["--mode", str(state["mode"])]
        if "color" in state:
            args += ["--color", str(state["color"])]
        if "brightness" in state:
            args += ["--brightness", str(int(state["brightness"]))]
        if "speed" in state:
            args += ["--speed", str(int(state["speed"]))]
        # Run silently — animation steps shouldn't print every frame.
        try:
            subprocess.run([sys.argv[0], *args],
                           stdout=subprocess.DEVNULL,
                           stderr=subprocess.DEVNULL, timeout=2)
        except Exception:
            pass
    # Note: `zone_colors` dict in animation step output is silently
    # ignored — per-zone WMBH access doesn't work on PH16-71 firmware.
    # Animations should set the global `color` for visible effect.


def cmd_lightbar_anim(args: argparse.Namespace) -> None:
    """Run a lightbar animation (foreground; Ctrl-C to stop)."""
    import importlib.util
    import signal as _signal

    _require_lightbar()
    if args.name == "list":
        anims = _list_lb_animations()
        if not anims:
            print("no lightbar animations found")
            return
        for name, p in sorted(anims.items()):
            spec = importlib.util.spec_from_file_location(name, p)
            mod = importlib.util.module_from_spec(spec)
            try:
                spec.loader.exec_module(mod)
                desc = getattr(mod, "DESCRIPTION", "")
            except Exception:
                desc = "(failed to import)"
            print(f"  {name:24s}  {desc}")
        return

    path = _find_lb_animation(args.name)
    spec = importlib.util.spec_from_file_location(path.stem, path)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    if not hasattr(mod, "step"):
        die(f"{path.name} doesn't define step(t)")
    fps = max(1, int(getattr(mod, "FPS", 10)))
    period = 1.0 / fps

    stop = {"v": False}
    def _sigterm(_a, _b): stop["v"] = True
    _signal.signal(_signal.SIGINT, _sigterm)
    _signal.signal(_signal.SIGTERM, _sigterm)

    print(f"running lightbar animation '{path.stem}' at {fps} FPS — Ctrl-C to stop")
    start = time.time()
    deadline = (start + args.timeout) if args.timeout > 0 else None
    while not stop["v"]:
        t = time.time() - start
        if deadline and time.time() >= deadline:
            break
        try:
            state = mod.step(t)
        except Exception as e:
            sys.stderr.write(f"animation step failed: {e}\n")
            break
        if isinstance(state, dict):
            _apply_lb_step(state)
        time.sleep(period)

    # Turn the bar off cleanly when the animation ends. The user can
    # rerun their last `lightbar set` to bring it back.
    try:
        subprocess.run([sys.argv[0], "lightbar", "off"],
                       stdout=subprocess.DEVNULL,
                       stderr=subprocess.DEVNULL, timeout=2)
    except Exception:
        pass
    print("animation stopped, lightbar off")


def cmd_tui(args: argparse.Namespace) -> None:
    """Launch the Textual TUI. Searches the usual install paths + a
    source checkout. Forwards any extra argv straight through.
    """
    candidates = [
        Path("/usr/local/share/venator/tui/tui.py"),
        Path("/usr/share/venator/tui/tui.py"),
        # Source checkout: alongside cli/venator
        Path(__file__).resolve().parent.parent / "tui" / "tui.py",
        # Or under /usr/local/bin's sibling /usr/local/share
        Path(sys.argv[0]).resolve().parent.parent / "share" / "venator" / "tui" / "tui.py",
    ]
    tui_path = next((p for p in candidates if p.is_file()), None)
    if tui_path is None:
        die("can't find tui.py — install via `sudo make install` "
            "or run from a source checkout (cli/ + tui/ as siblings)")
    extra = getattr(args, "tui_args", []) or []
    try:
        os.execvp(sys.executable, [sys.executable, str(tui_path), *extra])
    except OSError as e:
        die(f"failed to exec TUI: {e}")


