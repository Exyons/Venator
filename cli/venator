def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="venator")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("status", help="show device state").set_defaults(func=cmd_status)

    # ---- rgb high-level (all auto-apply)
    rgb = sub.add_parser("rgb", help="LED control").add_subparsers(dest="rgb_cmd", required=True)

    rs = rgb.add_parser("static", help="solid colour, every key the same")
    rs.add_argument("color", help="#RRGGBB")
    rs.add_argument("--brightness", type=int)
    _add_timeout_arg(rs)
    rs.set_defaults(func=cmd_rgb_static)

    re_ = rgb.add_parser("effect", help="run a named effect")
    re_.add_argument("name", help=f"one of: {' '.join(m for m in MODES if m not in ('off','static','perkey'))}")
    re_.add_argument("--color")
    re_.add_argument("--brightness", type=int)
    _add_timeout_arg(re_)
    re_.set_defaults(func=cmd_rgb_effect)

    rfill = rgb.add_parser("fill", help="per-key buffer: every key the same colour")
    rfill.add_argument("color", help="#RRGGBB")
    rfill.add_argument("--brightness", type=int)
    _add_timeout_arg(rfill)
    rfill.set_defaults(func=cmd_rgb_fill)

    rpk = rgb.add_parser("perkey", help="per-key buffer from hex or file (384 bytes RGB)")
    rpk.add_argument("data",
                     help="384-byte raw file, hex string of 768 chars, or @path/to/file")
    rpk.add_argument("--brightness", type=int)
    _add_timeout_arg(rpk)
    rpk.set_defaults(func=cmd_rgb_perkey)

    ri = rgb.add_parser("image", help="paint a PNG / JPG / etc. across the 128 cells (needs Pillow)")
    ri.add_argument("path", help="path to image file")
    ri.add_argument("--brightness", type=int)
    _add_timeout_arg(ri)
    ri.set_defaults(func=cmd_rgb_image)

    rd = rgb.add_parser("design", help="apply a one-shot static design (.json or .py)")
    rd.add_argument("name", nargs="?", help="design name (or path/to/file)")
    rd.add_argument("--list", action="store_true", help="list installed designs and exit")
    rd.add_argument("--brightness", type=int)
    _add_timeout_arg(rd)
    rd.set_defaults(func=cmd_rgb_design)

    rk = rgb.add_parser("key", help="paint one named key (requires a keymap)")
    rk.add_argument("name", help="key name as recorded by `map discover`")
    rk.add_argument("color", help="#RRGGBB")
    rk.add_argument("--brightness", type=int)
    _add_timeout_arg(rk)
    rk.set_defaults(func=cmd_rgb_key)

    rks = rgb.add_parser("keys", help="paint several named keys at once")
    rks.add_argument("names", help="comma-separated key names, e.g. 'W,A,S,D'")
    rks.add_argument("color", help="#RRGGBB")
    rks.add_argument("--brightness", type=int)
    _add_timeout_arg(rks)
    rks.set_defaults(func=cmd_rgb_keys)

    ra = rgb.add_parser("animate", help="run a custom animation script")
    ra.add_argument("name", nargs="?", help="animation name (or path/to/file.py)")
    ra.add_argument("--list", action="store_true", help="list installed animations and exit")
    ra.add_argument("--brightness", type=int)
    _add_timeout_arg(ra)
    ra.set_defaults(func=cmd_rgb_animate)

    rgb.add_parser("off", help="turn LEDs off").set_defaults(func=cmd_rgb_off)

    # ---- low-level (stage; --apply to commit)
    def low(parser_):
        parser_.add_argument("--apply", action="store_true",
                             help="commit immediately (otherwise stage only)")

    pm = sub.add_parser("mode", help="set mode (low-level; stages only)")
    pm.add_argument("name")
    low(pm); pm.set_defaults(func=cmd_mode)

    pc = sub.add_parser("color", help="set colour (low-level; stages only)")
    pc.add_argument("color", help="#RRGGBB")
    low(pc); pc.set_defaults(func=cmd_color)

    pb = sub.add_parser("brightness", help="set brightness 0..255 (low-level; stages only)")
    pb.add_argument("value", type=int)
    low(pb); pb.set_defaults(func=cmd_brightness)

    pe = sub.add_parser("effect-id", help="raw EFF byte override 0..255 (0 = use mode default)")
    pe.add_argument("value", type=lambda s: int(s, 0))
    low(pe); pe.set_defaults(func=cmd_effect_id)

    sub.add_parser("apply", help="commit pending state").set_defaults(func=cmd_apply)

    # ---- keymap
    mp = sub.add_parser("map", help="manage the cell -> physical-key map").add_subparsers(dest="map_cmd", required=True)

    md = mp.add_parser("discover",
                       help="walk the 128 cells one by one; record the physical key for each")
    md.add_argument("--start", type=int, default=0, help="first cell to discover")
    md.add_argument("--end",   type=int, default=128, help="one past the last cell")
    md.set_defaults(func=cmd_map_discover)

    ms = mp.add_parser("show", help="show the current keymap")
    ms.add_argument("--path", help="path to a keymap JSON (default: ~/.config/venator/keymap.json)")
    ms.set_defaults(func=cmd_map_show)

    mu = mp.add_parser("unset", help="remove a key mapping")
    mu.add_argument("name")
    mu.set_defaults(func=cmd_map_unset)

    # ---- profiles
    prof = sub.add_parser("profile", help="save / load named profiles").add_subparsers(dest="prof_cmd", required=True)

    ps = prof.add_parser("save"); ps.add_argument("name"); ps.set_defaults(func=cmd_profile_save)
    pl = prof.add_parser("load"); pl.add_argument("name"); pl.set_defaults(func=cmd_profile_load)
    prof.add_parser("list").set_defaults(func=cmd_profile_list)
    pd = prof.add_parser("delete"); pd.add_argument("name"); pd.set_defaults(func=cmd_profile_delete)
    psh = prof.add_parser("show",
        help="print the JSON of a saved profile (debug)")
    psh.add_argument("name"); psh.set_defaults(func=cmd_profile_show)

    # ---- power / thermal / battery (mainline acer-wmi wrappers)
    pw = sub.add_parser("power", help="get/set the laptop power profile "
                        "(quiet / balanced / performance / turbo / ...)")
    pw.add_argument("name", nargs="?",
                    help="profile name or alias (omit to print current + choices)")
    pw.add_argument("--detach-ppd", action="store_true",
                    help="mask EVERY active power manager (power-profiles-daemon, "
                         "tuned, auto-cpufreq, …) so none re-apply their own "
                         "profile on AC plug/unplug")
    pw.add_argument("--attach-ppd", action="store_true",
                    help="undo --detach-ppd (unmask + start whatever was masked)")
    pw.set_defaults(func=cmd_power)

    # Auto-link RGB scheme to power profile. Mapping kept in
    # ~/.config/venator/power-rgb.json; consulted on every
    # successful `power <profile>` call.
    pr = sub.add_parser(
        "power-rgb",
        help="link an RGB colour scheme to each power profile (turbo=red, "
        "balanced=white, etc.) so `power <profile>` also retints the keyboard",
    ).add_subparsers(dest="prgb_cmd", required=True)
    prs = pr.add_parser("set",
                        help="map a profile to a colour applied on profile-switch")
    prs.add_argument("profile",
                     help="profile name or alias (low-power/quiet/balanced/"
                     "performance/turbo or the raw kernel name)")
    prs.add_argument("color", help="#RRGGBB")
    prs.set_defaults(func=cmd_power_rgb_set)

    pru = pr.add_parser("unset", help="remove a profile->colour mapping")
    pru.add_argument("profile")
    pru.set_defaults(func=cmd_power_rgb_unset)

    pr.add_parser("list", help="show all profile->colour mappings + on/off state"
                  ).set_defaults(func=cmd_power_rgb_list)

    pr_en = pr.add_parser("enable",
                          help="enable auto-RGB on profile change (default ON after set)")
    pr_en.set_defaults(func=cmd_power_rgb_toggle, cmd_action="enable")
    pr_di = pr.add_parser("disable",
                          help="disable auto-RGB; mappings remain stored")
    pr_di.set_defaults(func=cmd_power_rgb_toggle, cmd_action="disable")

    pr.add_parser("apply",
                  help="force-apply the colour for the current profile NOW "
                       "(ignores global enable flag; useful for testing)"
                  ).set_defaults(func=cmd_power_rgb_apply)

    # Per-source power policy: separate profile for AC vs battery,
    # restored at login by the restore service. Stored in
    # ~/.config/venator/power-policy.json.
    ppol = sub.add_parser(
        "power-policy",
        help="set per-source power profiles (AC vs battery) that are "
             "restored at login; battery is limited to eco/quiet/balanced "
             "unless --advanced",
    )
    ppol_sub = ppol.add_subparsers(dest="ppol_cmd")
    ppol.set_defaults(func=cmd_power_policy)   # no subcommand → show

    ppol_ac = ppol_sub.add_parser("ac", help="set the on-AC profile (any profile)")
    ppol_ac.add_argument("profile",
                         help="profile name or alias (eco/quiet/balanced/"
                              "performance/turbo or the raw kernel name)")
    ppol_ac.set_defaults(func=cmd_power_policy_set, slot="ac")

    ppol_bat = ppol_sub.add_parser("battery",
                                   help="set the on-battery profile "
                                        "(eco/quiet/balanced; --advanced for more)")
    ppol_bat.add_argument("profile",
                          help="eco / quiet / balanced (performance / turbo "
                               "need --advanced)")
    ppol_bat.add_argument("--advanced", action="store_true",
                          help="allow performance/turbo on battery "
                               "(degrades battery health)")
    ppol_bat.set_defaults(func=cmd_power_policy_set, slot="battery")

    ppol_sub.add_parser("apply",
                        help="apply the profile for the current power source "
                             "now (used by the restore service at login)"
                        ).set_defaults(func=cmd_power_policy_apply)
    ppol_sub.add_parser("show",
                        help="show the current policy + power source"
                        ).set_defaults(func=cmd_power_policy)
    ppol_sub.add_parser("clear", help="delete the stored policy"
                        ).set_defaults(func=cmd_power_policy_clear)

    # Long-running daemon that re-applies the policy on AC plug/unplug so
    # the profile changes in real time. Run by the powerwatch user unit.
    pwatch = sub.add_parser(
        "power-watch",
        help="daemon: re-apply the AC/battery policy whenever the charger "
             "is plugged in or unplugged (run by the powerwatch service)")
    pwatch.add_argument("--interval", type=float, default=2.0,
                        help="seconds between AC-state polls (default 2.0)")
    pwatch.add_argument("--settle", type=float, default=1.0,
                        help="seconds to wait after a change before applying, "
                             "so we land after any other daemon (default 1.0)")
    pwatch.set_defaults(func=cmd_power_watch)

    bat = sub.add_parser("battery",
                         help="battery info / charge limit / behaviour"
                         ).add_subparsers(dest="bat_cmd", required=True)

    bat.add_parser("info", help="dump battery state").set_defaults(func=cmd_battery_info)

    bl = bat.add_parser("limit",
                        help="get/set the charge-stop limit (PH16-71 firmware "
                        "supports 80%% cap on/off; other boards may take any percent)")
    bl.add_argument("value", nargs="?",
                    help="'on' / 'off' / 1..100 (omit to read the current limit)")
    bl.set_defaults(func=cmd_battery_limit)

    bb = bat.add_parser("behaviour",
                        help="get/set charge_behaviour (auto / inhibit-charge / ...)")
    bb.add_argument("name", nargs="?")
    bb.set_defaults(func=cmd_battery_behaviour)

    misc = sub.add_parser(
        "misc",
        help="LCD overdrive, boot sound, etc — gaming-misc toggles via WMBH "
             "(needs /sys/class/venator/gaming0 from the kernel module)")
    misc.add_argument("feature", nargs="?",
                      help=f"one of: {', '.join(sorted(_MISC_ATTRS))} "
                           "(omit to dump status of all)")
    misc.add_argument("value", nargs="?",
                      help="on/off (omit to read current state of one feature)")
    misc.set_defaults(func=cmd_misc)

    # ---- lightbar (rear 3-zone EC RGB strip on PH16-71) ------------
    lb = sub.add_parser(
        "lightbar",
        help="rear lightbar control (needs /sys/class/venator/lightbar0 "
             "from the kernel module). Modes: " + ", ".join(LB_MODES),
        description=(
            "Control the Predator rear lightbar via the WMBH AcerGamingFunction\n"
            "WMI method (decoded from AcerECLightbarController.dll). Use the\n"
            "atomic 'set' form for the common case — one WMI call updates\n"
            "everything at once. Individual mode/color/brightness/speed\n"
            "subcommands are equivalent but each does its own commit."),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    lbs = lb.add_subparsers(dest="lb_cmd", required=True)

    lbs.add_parser("status",
                   help="dump current mode/color/brightness/speed"
                   ).set_defaults(func=cmd_lightbar_status)

    lbs.add_parser("off",
                   help="turn the lightbar off"
                   ).set_defaults(func=cmd_lightbar_off)

    lbs.add_parser("modes",
                   help="list available modes"
                   ).set_defaults(func=cmd_lightbar_modes)

    lbs.add_parser("apply",
                   help="re-commit the kernel-cached state (no value change)"
                   ).set_defaults(func=cmd_lightbar_apply)

    lbw = lbs.add_parser(
        "wake",
        help="recover a stuck-off lightbar by replaying the breathing→"
             "<target> init sequence the firmware needs after a reset")
    lbw.add_argument("--mode", default="static",
                     help="final mode to leave the bar in (default: static)")
    lbw.set_defaults(func=cmd_lightbar_wake)

    lbm = lbs.add_parser("mode", help="set the effect mode")
    lbm.add_argument("name", help="one of: " + ", ".join(LB_MODES))
    lbm.set_defaults(func=cmd_lightbar_mode)

    lbc = lbs.add_parser("color", help="set RGB colour")
    lbc.add_argument("color", help="RRGGBB hex (e.g. ff0000 for red)")
    lbc.set_defaults(func=cmd_lightbar_color)

    lbb = lbs.add_parser("brightness", help="set brightness 0..255")
    lbb.add_argument("value", type=int)
    lbb.set_defaults(func=cmd_lightbar_brightness)

    lbsp = lbs.add_parser("speed", help="set animation speed 0..255")
    lbsp.add_argument("value", type=int)
    lbsp.set_defaults(func=cmd_lightbar_speed)

    lbset = lbs.add_parser(
        "set",
        help="atomic update — one WMI call updates all fields at once "
             "(unset fields keep their current value)")
    lbset.add_argument("--mode",
                       help="one of: " + ", ".join(LB_MODES))
    lbset.add_argument("--color",
                       help="RRGGBB hex colour")
    lbset.add_argument("--brightness", type=int,
                       help="0..255 brightness")
    lbset.add_argument("--speed", type=int,
                       help="0..255 animation speed")
    lbset.set_defaults(func=cmd_lightbar_set)

    # Per-zone colour was attempted via WMBH method 6 (SetGamingRgbKb)
    # but the firmware on PH16-71 rejects every input combination we
    # tested, so it is not exposed. If a future chassis turns out to
    # support it, a `zone-color` subcommand can be added here.

    lba = lbs.add_parser(
        "anim",
        help="run a lightbar animation (foreground; Ctrl-C to stop). "
             "Pass 'list' to see what's available.")
    lba.add_argument("name",
                     help="animation name (without .py), an absolute "
                          "path to a .py file, or 'list'")
    lba.add_argument("--timeout", type=int, default=0,
                     help="stop after N seconds (0 = run forever)")
    lba.set_defaults(func=cmd_lightbar_anim)

    # ---- unified themes (keyboard + lightbar coordinated) --------------
    uni = sub.add_parser(
        "unified",
        help="apply a synchronised keyboard+lightbar theme in one shot. "
             "Themes are JSON files under cli/designs/unified/ and "
             "~/.config/venator/designs/unified/."
    ).add_subparsers(dest="uni_cmd", required=True)

    uni.add_parser(
        "list", help="list built-in + user unified themes"
    ).set_defaults(func=cmd_unified_list)

    ua = uni.add_parser("apply", help="apply a unified theme to both")
    ua.add_argument("name",
                    help="theme name (without .json) or absolute path")
    ua.add_argument("--timeout", type=parse_timeout, default=None,
                    help="auto-off after N seconds (applies to keyboard half)")
    ua.set_defaults(func=cmd_unified_apply)

    us = uni.add_parser(
        "save", help="snapshot the current state into a new unified theme")
    us.add_argument("name", help="theme name (used as filename)")
    us.add_argument("--description", default=None)
    us.set_defaults(func=cmd_unified_save)

    una = uni.add_parser(
        "anim",
        help="run a synchronized keyboard+lightbar animation "
             "(foreground; Ctrl-C to stop). Pass 'list' to see available.")
    una.add_argument("name",
                     help="animation name (without .py), an absolute "
                          "path to a .py file, or 'list'")
    una.add_argument("--timeout", type=int, default=0,
                     help="stop after N seconds (0 = run forever)")
    una.set_defaults(func=cmd_unified_anim)

    # ---- TUI launcher --------------------------------------------------
    tp = sub.add_parser(
        "tui",
        help="launch the Textual TUI (live keyboard preview + lightbar + "
             "power + battery tabs)")
    tp.add_argument("tui_args", nargs=argparse.REMAINDER,
                    help="extra args passed through to tui.py")
    tp.set_defaults(func=cmd_tui)

    sub.add_parser(
        "thermal",
        help="dump fan RPMs + CPU/GPU/chassis/nvme temps",
        description=(
            "Dumps the acer-wmi hwmon device (mainline doesn't label its "
            "inputs, so we relabel them):\n"
            "  fan1   = left  blower (CPU side)         (EC codename CPUF/EFAN)\n"
            "  fan2   = right blower (GPU side)         (EC codename GPUF)\n"
            "  temp1  = CPU package sensor              (EC codename CTMP)\n"
            "  temp2  = GPU sensor — 0 when dGPU sleeps (EC codename GTMP)\n"
            "  temp3  = chassis / palmrest ambient       (EC codename STMP)\n"
            "\n"
            "Also pulls coretemp's CPU package and the nvme composite for "
            "cross-checking (acer/temp1 reads via EC; coretemp reads MSRs "
            "directly off the die, so they should agree within ~2 °C)."),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    ).set_defaults(func=cmd_thermal)

    sub.add_parser(
        "fan",
        help="dump fan RPMs only",
        description=(
            "Fan RPMs from the acer-wmi hwmon device:\n"
            "  fan1 = left  blower (CPU side, EC fan tach 0x00..0x07)\n"
            "  fan2 = right blower (GPU side, EC fan tach 0x10..0x17)"),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    ).set_defaults(func=cmd_fan)

    # Hidden internal subcommand used by start_animator() / start_keepalive()
    # to run loops in the detached child. Not for user invocation.
    rl = sub.add_parser("_run-loop", help=argparse.SUPPRESS)
    rlg = rl.add_mutually_exclusive_group(required=True)
    rlg.add_argument("--anim",      help=argparse.SUPPRESS)
    rlg.add_argument("--keepalive", action="store_true", help=argparse.SUPPRESS)
    rl.add_argument("--brightness", type=int, help=argparse.SUPPRESS)
    rl.add_argument("--timeout",    type=int, default=0, help=argparse.SUPPRESS)
    rl.set_defaults(func=cmd__run_loop)

    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    args.func(args)
    return 0


if __name__ == "__main__":
    sys.exit(main())
