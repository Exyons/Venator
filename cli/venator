# SPDX-License-Identifier: GPL-2.0-only
"""
venator -- userspace CLI for the venator kernel module.

Talks to /sys/class/venator/keyboard<N>/ exclusively. See docs/sysfs.md
for the ABI.

Most subcommands stage state and then `apply`, so a single high-level
call (e.g. `venator rgb static '#ff0000'`) results in one
hardware transaction. The lower-level `mode`, `color`, `brightness`,
`effect-id` subcommands only stage -- run `venator apply` when
you're done tweaking, or use `--apply` on the last one.

Writing /sys requires either root or membership in the `venator`
group (udev rule -- see Phase 4).
"""
from __future__ import annotations

import argparse
import binascii
import glob
import datetime
import json
import os
import re
import select
import signal
import subprocess
import sys
import time
from pathlib import Path
from typing import Iterable

SYSFS_ROOT = Path("/sys/class/venator")


def _real_home() -> Path:
    """Return the invoking user's home dir even when we've been re-exec'd
    as root via sudo. Without this, KEYMAP and profile JSON end up in
    /root/.config/venator and the user can't access them once they
    drop privileges.
    """
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user and os.geteuid() == 0:
        try:
            import pwd
            return Path(pwd.getpwnam(sudo_user).pw_dir)
        except (KeyError, ImportError):
            pass
    return Path(os.path.expanduser("~"))


def _chown_to_invoker(path: Path) -> None:
    """If running as root via sudo, hand ownership of `path` to the
    invoking user. No-op for pure root or non-root.
    """
    sudo_user = os.environ.get("SUDO_USER")
    if not sudo_user or os.geteuid() != 0:
        return
    try:
        import pwd
        pw = pwd.getpwnam(sudo_user)
        os.chown(str(path), pw.pw_uid, pw.pw_gid)
    except (KeyError, OSError, ImportError):
        pass


PROFILE_DIR = _real_home() / ".config" / "venator" / "profiles"
RUNTIME_DIR = _real_home() / ".cache" / "venator"
BG_PID_FILE = RUNTIME_DIR / "background.pid"
DEFAULT_PROFILE_NAME = "default"
KEEPALIVE_INTERVAL_S = 30.0
SCRIPT_PATH = str(Path(__file__).resolve())

# --timeout default. 0 = no auto-limit (the natural behaviour for both
# static and animation modes). Capped at 60 per the user-facing contract.
# When >0 the worker exits after that many seconds. The exit semantics
# differ between static and animation -- see _loop_keepalive and
# _loop_animation.
DEFAULT_TIMEOUT_S = 0
TIMEOUT_MAX_S     = 60


def parse_timeout(v) -> int:
    try:
        t = int(v)
    except (TypeError, ValueError):
        raise argparse.ArgumentTypeError(f"timeout must be an integer 0..{TIMEOUT_MAX_S}")
    if not (0 <= t <= TIMEOUT_MAX_S):
        raise argparse.ArgumentTypeError(f"timeout must be 0..{TIMEOUT_MAX_S} seconds")
    return t


def _add_timeout_arg(parser, default=DEFAULT_TIMEOUT_S):
    parser.add_argument(
        "--timeout", type=parse_timeout, default=default,
        help=(f"override how long the LEDs stay lit, in seconds (0..{TIMEOUT_MAX_S}). "
              f"Default 0 means 'no override' -- static modes use the EC's natural "
              f"idle (dim after ~60s, wake on keypress); animations run forever. "
              f"For static modes, a positive value runs a keepalive for N seconds "
              f"then hands off to the EC. For animations, a positive value stops "
              f"the animation at N seconds and turns the LEDs off cleanly (no "
              f"wake-on-keypress, since you explicitly asked for shutoff)."),
    )

# Modes supported by the kernel (kept in sync with venator.h).
MODES = ("off", "static", "breathing", "rainbow", "snake", "ripple",
         "neon", "rain", "explosion", "pulse", "stars", "meteor",
         "aura", "perkey")

# Modes that use the `color` attribute. Mirrors docs/sysfs.md.
COLOUR_MODES = {"static", "breathing", "snake", "ripple", "rain",
                "explosion", "pulse", "stars", "meteor", "aura"}

# Bytes the kernel's `frame` attribute expects: 128 cells x 3 bytes RGB.
PERKEY_BYTES = 128 * 3


# --------------------------------------------------------------- helpers

def die(msg: str, code: int = 1) -> None:
    print(f"venator: {msg}", file=sys.stderr)
    sys.exit(code)


def find_device() -> Path:
    """Locate the keyboard sysfs device under /sys/class/venator/.

    Phase 6 added a sibling `battery0` device under the same class.
    A plain "first directory" pick will now sometimes return the
    battery device and then every rgb command dies looking for
    /sys/class/venator/battery0/mode. Filter for keyboard* (which
    is the only name the HID driver in venator-main.c
    creates), with a sanity check that the picked entry has the
    expected LED attributes.
    """
    if not SYSFS_ROOT.exists():
        die(f"{SYSFS_ROOT} not found -- is the venator module loaded?")
    kbds = sorted(p for p in SYSFS_ROOT.iterdir()
                  if p.is_dir() and p.name.startswith("keyboard"))
    if not kbds:
        # Fall back to "any dir with a `mode` attr" so we keep working
        # if a future revision renames the device class.
        for p in sorted(SYSFS_ROOT.iterdir()):
            if p.is_dir() and (p / "mode").exists():
                return p
        die(f"no keyboard device under {SYSFS_ROOT}")
    return kbds[0]


def write_text_attr(dev: Path, attr: str, value: str) -> None:
    path = dev / attr
    if not path.exists():
        die(f"{path} not found")
    try:
        path.write_text(value)
    except PermissionError:
        die(f"permission denied writing {path}.\n"
            f"  Run with sudo, or add yourself to the 'venator' group "
            f"once the udev rule is installed.")
    except OSError as e:
        die(f"write to {path} failed: {e}")


def write_bin_attr(dev: Path, attr: str, data: bytes) -> None:
    path = dev / attr
    if not path.exists():
        die(f"{path} not found")
    try:
        with path.open("wb") as f:
            f.write(data)
    except PermissionError:
        die(f"permission denied writing {path}")
    except OSError as e:
        die(f"write to {path} failed: {e}")


def read_text_attr(dev: Path, attr: str, default: str = "") -> str:
    path = dev / attr
    if not path.exists():
        return default
    try:
        return path.read_text().strip()
    except OSError:
        return default


def parse_rgb(s: str) -> tuple[int, int, int]:
    m = re.fullmatch(r"#?([0-9a-fA-F]{6})", s)
    if not m:
        die(f"invalid colour {s!r} -- expected #RRGGBB")
    h = m.group(1)
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def rgb_hex(r: int, g: int, b: int) -> str:
    return f"#{r:02x}{g:02x}{b:02x}"


def commit(dev: Path) -> None:
    write_text_attr(dev, "apply", "1")


# --------------------------------------------------------------- frame helpers

def frame_from_solid(r: int, g: int, b: int) -> bytes:
    return bytes([r, g, b]) * 128


def frame_from_hex(h: str) -> bytes:
    h = h.replace(" ", "").replace(":", "").replace("\n", "")
    try:
        data = binascii.unhexlify(h)
    except binascii.Error as e:
        die(f"bad hex: {e}")
    if len(data) != PERKEY_BYTES:
        die(f"hex decodes to {len(data)} bytes, need {PERKEY_BYTES}")
    return data


def frame_from_file(path: Path) -> bytes:
    try:
        data = path.read_bytes()
    except OSError as e:
        die(f"cannot read {path}: {e}")
    if len(data) == PERKEY_BYTES:
        return data
    # Allow hex-encoded files too.
    try:
        text = data.decode("ascii")
    except UnicodeDecodeError:
        die(f"{path}: {len(data)} bytes raw, expected {PERKEY_BYTES} "
            f"(or a hex-encoded text file)")
    return frame_from_hex(text)


def parse_frame_arg(arg: str) -> bytes:
    # "@filename" -> read from file. Otherwise, treat as hex string.
    if arg.startswith("@"):
        return frame_from_file(Path(arg[1:]))
    p = Path(arg)
    if p.exists() and p.is_file():
        return frame_from_file(p)
    return frame_from_hex(arg)


# --------------------------------------------------- background process

def _ensure_runtime_dir() -> None:
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    _chown_to_invoker(RUNTIME_DIR)


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        # exists, just owned by someone else
        return True


def stop_background() -> None:
    """Kill the previously-spawned animation / keepalive process, if any.

    Silently survives the case where the PID is dead or owned by another
    user (e.g. user mixed sudo and non-sudo). On permission failure we
    just clear the PID file and move on -- the orphan will exit when
    its writes start failing, or the user can `pkill -f venator`.
    """
    if not BG_PID_FILE.exists():
        return
    try:
        pid = int(BG_PID_FILE.read_text().strip())
    except (OSError, ValueError):
        BG_PID_FILE.unlink(missing_ok=True)
        return
    try:
        os.kill(pid, signal.SIGTERM)
        # Wait briefly for it to exit.
        for _ in range(20):
            if not _pid_alive(pid):
                break
            time.sleep(0.05)
        else:
            try:
                os.kill(pid, signal.SIGKILL)
            except (ProcessLookupError, PermissionError):
                pass
    except ProcessLookupError:
        pass
    except PermissionError:
        pass  # owned by another user; user has to clean up manually
    BG_PID_FILE.unlink(missing_ok=True)


def _spawn_background(args: list[str]) -> int:
    _ensure_runtime_dir()
    proc = subprocess.Popen(
        args,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True,
    )
    BG_PID_FILE.write_text(str(proc.pid))
    _chown_to_invoker(BG_PID_FILE)
    return proc.pid


def start_animator(name: str, brightness: int | None, timeout: int = 0) -> None:
    stop_background()
    args = [sys.executable, SCRIPT_PATH, "_run-loop", "--anim", name,
            "--timeout", str(timeout)]
    if brightness is not None:
        args += ["--brightness", str(brightness)]
    _spawn_background(args)


def start_keepalive(timeout: int) -> None:
    """Spawn the keepalive worker. With timeout > 0 it re-pokes `apply`
    every KEEPALIVE_INTERVAL_S seconds for that many seconds and then
    exits, leaving the EC to handle the natural idle-off + wake-on-
    keypress. With timeout == 0 we don't spawn anything -- the user
    asked for the natural EC behaviour without override, which means
    just one initial apply (the high-level command already did that).
    """
    stop_background()
    if timeout <= 0:
        return
    args = [sys.executable, SCRIPT_PATH, "_run-loop", "--keepalive",
            "--timeout", str(timeout)]
    _spawn_background(args)


# --------------------------------------------------- auto-saved default profile

# A "static" autosaved profile mirrors the current sysfs state and the
# frame buffer; on restore we just write those back and apply. An
# "animation" autosaved profile remembers the animation name so on
# restore we respawn the animator.

def _snapshot_lightbar() -> dict | None:
    """Read the current kernel-cached lightbar state. Returns None if
    the lightbar driver isn't bound (no /sys/class/venator/lightbar0).
    """
    if not VENATOR_LIGHTBAR_DIR.exists():
        return None
    out: dict = {}
    for attr in ("mode", "brightness", "speed", "direction", "color"):
        p = VENATOR_LIGHTBAR_DIR / attr
        if p.exists():
            try:
                out[attr] = p.read_text().strip()
            except OSError:
                pass
    return out or None


def _autosave_lightbar() -> None:
    """Mirror the lightbar half of save_default(): snapshot the
    lightbar state into the `default` profile alongside the keyboard
    state. Called on every CLI lightbar mutation.
    """
    snap_path = PROFILE_DIR / f"{DEFAULT_PROFILE_NAME}.json"
    existing: dict = {}
    if snap_path.exists():
        try:
            existing = json.loads(snap_path.read_text())
        except (OSError, ValueError):
            existing = {}
    lb = _snapshot_lightbar()
    if lb is None:
        return
    existing["lightbar"] = lb
    existing.setdefault("_autosaved", True)
    # Ensure dirs are owned by the invoking user (handles sudo).
    parts: list[Path] = []
    p = PROFILE_DIR
    while not p.exists() and p != p.parent:
        parts.append(p); p = p.parent
    PROFILE_DIR.mkdir(parents=True, exist_ok=True)
    for created in reversed(parts):
        _chown_to_invoker(created)
    snap_path.write_text(json.dumps(existing, indent=2, sort_keys=True))
    _chown_to_invoker(snap_path)


def save_default(dev: Path, *, animation_name: str | None = None,
                 timeout: int = 0) -> None:
    snap: dict[str, object] = {
        "_autosaved": True,
        "mode":       read_text_attr(dev, "mode"),
        "color":      read_text_attr(dev, "color"),
        "brightness": read_text_attr(dev, "brightness"),
        "effect_id":  read_text_attr(dev, "effect_id"),
        "timeout":    int(timeout),
    }
    if animation_name:
        snap["animation_name"] = animation_name
    # Capture the per-key frame too so designs/perkey paint restores 1:1.
    try:
        frame = (dev / "frame").read_bytes()
        if len(frame) == PERKEY_BYTES:
            snap["frame_hex"] = frame.hex()
    except OSError:
        pass
    # Capture the lightbar state too so `profile load default` restores
    # both halves in one go. Skipped silently if the lightbar driver
    # isn't bound (different kernel build, module unloaded, etc.).
    lb = _snapshot_lightbar()
    if lb is not None:
        snap["lightbar"] = lb

    # Ensure dirs are owned by the invoking user (handles sudo).
    parts: list[Path] = []
    p = PROFILE_DIR
    while not p.exists() and p != p.parent:
        parts.append(p); p = p.parent
    PROFILE_DIR.mkdir(parents=True, exist_ok=True)
    for created in reversed(parts):
        _chown_to_invoker(created)
    out = PROFILE_DIR / f"{DEFAULT_PROFILE_NAME}.json"
    out.write_text(json.dumps(snap, indent=2, sort_keys=True))
    _chown_to_invoker(out)


# --------------------------------------------------------------- keymap

KEYMAP_DEFAULT = _real_home() / ".config" / "venator" / "keymap.json"


def _shipped_keymap() -> Path:
    """The bundled PH16-71 keymap. `make install` copies this into the
    user's config, but fall back to it directly so per-key painting by
    name works out of the box even on a fresh checkout / partial install.
    """
    return _find_shipped_dir("keymaps") / "ph16-71.json"


def load_keymap(path: Path | None = None) -> dict:
    explicit = path is not None
    path = path or KEYMAP_DEFAULT
    # No user keymap yet: fall back to the shipped PH16-71 one (read-only)
    # so `rgb key`/`rgb keys` work before the user runs `map discover`.
    if not explicit and not path.exists():
        shipped = _shipped_keymap()
        if shipped.exists():
            path = shipped
    if not path.exists():
        return {"model": "Predator PH16-71", "num_cells": 128, "keys": {}}
    try:
        m = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError) as e:
        die(f"bad keymap {path}: {e}")
    m.setdefault("keys", {})
    m.setdefault("num_cells", 128)
    return m


def save_keymap(m: dict, path: Path | None = None) -> Path:
    path = path or KEYMAP_DEFAULT
    # mkdir the leaf and every intermediate, chowning each to the real
    # user if we're running under sudo (so they own the file afterwards).
    parts = []
    p = path.parent
    while not p.exists() and p != p.parent:
        parts.append(p); p = p.parent
    path.parent.mkdir(parents=True, exist_ok=True)
    for created in reversed(parts):
        _chown_to_invoker(created)
    path.write_text(json.dumps(m, indent=2, sort_keys=True))
    _chown_to_invoker(path)
    return path


def base_frame_from_state(dev: Path) -> bytearray:
    """Return a 384-byte buffer reflecting the keyboard's current visual
    state, suitable for layering per-key edits onto.

    - mode=perkey: use the current frame attr.
    - mode in COLOUR_MODES with a colour set: fill with that colour.
    - else: all off.
    """
    mode = read_text_attr(dev, "mode")
    if mode == "perkey":
        try:
            return bytearray((dev / "frame").read_bytes()[:PERKEY_BYTES])
        except OSError:
            return bytearray(PERKEY_BYTES)
    if mode in COLOUR_MODES:
        col = read_text_attr(dev, "color")
        m_ = re.fullmatch(r"#?([0-9a-fA-F]{6})", col or "")
        if m_:
            h = m_.group(1)
            r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
            return bytearray([r, g, b] * 128)
    return bytearray(PERKEY_BYTES)


def apply_cell_edits(dev: Path, edits: list[tuple[int, int, int, int]],
                     announce_basis: bool = True) -> None:
    """edits = [(cell, r, g, b), ...]. Modifies the current visual state
    and switches into perkey mode.
    """
    cur_mode = read_text_attr(dev, "mode")
    if announce_basis and cur_mode not in ("perkey",) and cur_mode not in COLOUR_MODES:
        print(f"note: current mode is {cur_mode!r} (no solid colour to inherit); "
              f"per-key edit starts from an off keyboard.", file=sys.stderr)
    frame = base_frame_from_state(dev)
    for cell, r, g, b in edits:
        if 0 <= cell < 128:
            frame[cell * 3 + 0] = r
            frame[cell * 3 + 1] = g
            frame[cell * 3 + 2] = b
    write_bin_attr(dev, "frame", bytes(frame))
    write_text_attr(dev, "mode", "perkey")
    commit(dev)


# --------------------------------------------------------------- animations

def _find_shipped_dir(name: str) -> Path:
    """Where the shipped designs/animations live. Source-tree wins if we're
    running from a checkout (cli/<name>/ next to this script); otherwise
    fall back to /usr/share or /usr/local/share for installed copies.
    """
    here = Path(__file__).resolve().parent
    if (here / name).exists():
        return here / name
    for sysdir in ("/usr/local/share/venator", "/usr/share/venator"):
        p = Path(sysdir) / name
        if p.exists():
            return p
    return here / name


ANIM_SHIPPED_DIR = _find_shipped_dir("animations")
ANIM_USER_DIR    = _real_home() / ".config" / "venator" / "animations"


def list_animations() -> dict:
    """Return {name: path}. Shipped animations first; user overrides shipped."""
    out: dict[str, Path] = {}
    for d in (ANIM_SHIPPED_DIR, ANIM_USER_DIR):
        if not d.exists():
            continue
        for f in sorted(d.glob("*.py")):
            if f.stem.startswith("_") or f.stem == "README":
                continue
            out[f.stem] = f
    return out


def find_animation(arg: str) -> Path:
    p = Path(arg)
    if p.suffix == ".py" and p.exists():
        return p
    anims = list_animations()
    if arg in anims:
        return anims[arg]
    names = ", ".join(sorted(anims)) or "<none>"
    die(f"animation {arg!r} not found. Available: {names}\n"
        f"  Drop .py files in {ANIM_USER_DIR} to add your own.")


def load_animation(path: Path):
    import importlib.util
    spec = importlib.util.spec_from_file_location("ps_anim", path)
    if not spec or not spec.loader:
        die(f"cannot load {path}")
    mod = importlib.util.module_from_spec(spec)
    try:
        spec.loader.exec_module(mod)
    except Exception as e:
        die(f"{path}: load failed: {e!r}")
    if not hasattr(mod, "render") or not callable(mod.render):
        die(f"{path}: missing render(t, num_cells, keymap) function")
    return mod


def cmd_rgb_animate(args: argparse.Namespace) -> None:
    if args.list:
        anims = list_animations()
        if not anims:
            print(f"  no animations installed")
            print(f"  shipped: {ANIM_SHIPPED_DIR}")
            print(f"  user:    {ANIM_USER_DIR}")
            return
        for name, path in sorted(anims.items()):
            origin = "shipped" if path.parent == ANIM_SHIPPED_DIR else "user"
            print(f"  {name:24s} [{origin}]  {path}")
        return
    if not args.name:
        die("usage: venator rgb animate <name> | rgb animate --list")

    # Resolve the animation now so we fail fast on a typo (the detached
    # child won't have a terminal to complain at).
    find_animation(args.name)

    # Save default first so a crash in the spawn doesn't lose state.
    dev = find_device()
    write_text_attr(dev, "mode", "perkey")
    if args.brightness is not None:
        write_text_attr(dev, "brightness", str(args.brightness))
    save_default(dev, animation_name=args.name, timeout=args.timeout)

    start_animator(args.name, args.brightness, args.timeout)
    msg = f"animation '{args.name}' running in the background"
    if args.timeout > 0:
        msg += f" (auto-off in {args.timeout}s)"
    print(msg + ". `rgb static` / `rgb off` / `rgb design ...` will stop it.")


# Hidden "_run-loop" subcommand. Used internally by start_animator() and
# start_keepalive() to run the actual loop in a detached child process.
# Not for direct user invocation.

def _turn_off(dev: Path) -> None:
    """Active mode=off + apply.

    The EC sees this as "active state at zero brightness" and won't fire
    its built-in wake-on-keypress -- which is fine, because the background
    workers reach this path only when they're going to start watching
    /dev/input/event*-kbd themselves and reapply state on the next
    keystroke.
    """
    try:
        write_text_attr(dev, "mode", "off")
        write_text_attr(dev, "apply", "1")
    except SystemExit:
        pass


# ---- keyboard activity monitoring (evdev /dev/input/event*) ---------------
#
# The EC supports wake-on-keypress only for its own built-in effects. For
# our custom designs / animations the mode=off state we set at the timeout
# deadline puts the EC into "active zero-brightness", which suppresses its
# wake. So we replicate the wake behaviour in userspace by reading
# struct input_event from /dev/input/by-path/*-event-kbd ourselves.
#
# Requires the worker's UID to be in the `input` group (install.sh adds
# the invoking user). When the worker can't open any event devices we
# silently degrade to "no wake-on-keypress" instead of crashing.

_INPUT_EVENT_SIZE = 24       # struct input_event on x86_64 (sec, usec, type, code, value)
_EV_KEY = 1
# Keyboard-backlight brightness keys (linux/input-event-codes.h). In
# per-key / direct mode the keyboard MCU ignores its own Fn brightness
# keys, so animations don't dim when you press them. We catch the key
# events here and fold them into the brightness our per-frame apply
# sends, which is what makes the keys work during an animation.
_KEY_KBDILLUMDOWN = 229
_KEY_KBDILLUMUP   = 230


def _open_keyboard_event_devices() -> list[int]:
    fds: list[int] = []
    for path in glob.glob("/dev/input/by-path/*-event-kbd"):
        try:
            fds.append(os.open(path, os.O_RDONLY | os.O_NONBLOCK))
        except OSError:
            continue
    return fds


def _drain_kbd_events_ex(fds: list[int]) -> tuple[bool, int]:
    """Read pending events from any fd. Returns (saw_press, bright_delta):

      saw_press     True if at least one key PRESS (value=1) was seen —
                    drives wake-on-keypress.
      bright_delta  net brightness-key steps (+1 per KBDILLUMUP, -1 per
                    KBDILLUMDOWN), counting press AND autorepeat so a
                    held key keeps ramping.
    """
    if not fds:
        return (False, 0)
    try:
        ready, _, _ = select.select(fds, [], [], 0)
    except (OSError, ValueError):
        return (False, 0)
    saw = False
    delta = 0
    for fd in ready:
        try:
            data = os.read(fd, _INPUT_EVENT_SIZE * 64)
        except (BlockingIOError, OSError):
            continue
        for i in range(0, len(data), _INPUT_EVENT_SIZE):
            chunk = data[i:i + _INPUT_EVENT_SIZE]
            if len(chunk) < _INPUT_EVENT_SIZE:
                break
            ev_type  = int.from_bytes(chunk[16:18], "little")
            ev_code  = int.from_bytes(chunk[18:20], "little")
            ev_value = int.from_bytes(chunk[20:24], "little", signed=True)
            if ev_type != _EV_KEY:
                continue
            if ev_value == 1:
                saw = True
            if ev_value in (1, 2):   # press or autorepeat
                if ev_code == _KEY_KBDILLUMUP:
                    delta += 1
                elif ev_code == _KEY_KBDILLUMDOWN:
                    delta -= 1
    return (saw, delta)


def _drain_kbd_events(fds: list[int]) -> bool:
    """Back-compat wrapper: True if any key PRESS was seen."""
    return _drain_kbd_events_ex(fds)[0]


def _close_fds(fds: list[int]) -> None:
    for fd in fds:
        try:
            os.close(fd)
        except OSError:
            pass


def _restore_static_default(dev: Path) -> None:
    """Re-apply the auto-saved 'default' profile's static fields. Called
    by the keepalive worker when it sees a keypress after an idle-off.
    """
    profile_path = PROFILE_DIR / f"{DEFAULT_PROFILE_NAME}.json"
    if not profile_path.exists():
        return
    try:
        snap = json.loads(profile_path.read_text())
    except (OSError, json.JSONDecodeError):
        return
    if snap.get("animation_name"):
        return  # animation, not static; the animator worker handles its own resume
    fhex = snap.get("frame_hex")
    if fhex:
        try:
            write_bin_attr(dev, "frame", bytes.fromhex(fhex))
        except (ValueError, SystemExit):
            pass
    for k in ("mode", "color", "brightness", "effect_id"):
        v = snap.get(k)
        if v:
            try:
                write_text_attr(dev, k, str(v))
            except SystemExit:
                pass
    try:
        write_text_attr(dev, "apply", "1")
    except SystemExit:
        pass


def _loop_animation(name: str, brightness: int | None, timeout: int = 0) -> None:
    """Render the animation in a background loop.

    timeout == 0  (default):   render forever, no idle handling.
    timeout >  0:              after `timeout` seconds with no keypress
                               on any /dev/input/by-path/*-event-kbd,
                               turn LEDs off (mode=off) AND pause rendering.
                               When a key is pressed, restore mode=perkey,
                               re-set brightness, and resume rendering at
                               the time we paused (so the animation
                               doesn't "skip ahead" silently).
    """
    mod = load_animation(find_animation(name))
    fps = float(getattr(mod, "FPS", 30))
    if fps < 1:
        fps = 1
    interval = 1.0 / fps
    keymap = load_keymap()
    dev = find_device()
    write_text_attr(dev, "mode", "perkey")

    # Brightness the per-frame apply sends. The MCU ignores its own Fn
    # brightness keys in per-key mode, so we implement them: cur_bright
    # starts from the requested value (or the live sysfs value) and the
    # event loop below nudges it on KBDILLUMUP/DOWN. BRIGHT_STEP gives ~8
    # levels across 0..255.
    BRIGHT_STEP = 32
    if brightness is not None:
        cur_bright = brightness
    else:
        try:
            cur_bright = int(read_text_attr(dev, "brightness"))
        except (ValueError, TypeError):
            cur_bright = 200
    cur_bright = max(0, min(255, cur_bright))
    write_text_attr(dev, "brightness", str(cur_bright))

    # Always open the kbd event devices (not just for the idle timeout)
    # so the brightness keys work even with timeout=0. Degrades silently
    # to "no brightness keys" if we can't open them (no input group).
    kbd_fds = _open_keyboard_event_devices()

    elapsed       = 0.0                # animation-time accumulator (excludes paused durations)
    last_tick     = time.monotonic()   # wall-clock at last frame
    last_activity = time.monotonic()
    paused        = False

    try:
        while True:
            now = time.monotonic()

            saw_press, bright_delta = _drain_kbd_events_ex(kbd_fds)

            # Fn brightness keys: fold into cur_bright and push to sysfs so
            # the next frame's apply uses it. Works whether or not a
            # timeout is set.
            if bright_delta:
                cur_bright = max(0, min(255, cur_bright + bright_delta * BRIGHT_STEP))
                try:
                    write_text_attr(dev, "brightness", str(cur_bright))
                except SystemExit:
                    pass

            if kbd_fds and saw_press:
                last_activity = now
                if paused:
                    # Wake: restore perkey mode + brightness, then resume rendering.
                    paused = False
                    try:
                        write_text_attr(dev, "mode", "perkey")
                        write_text_attr(dev, "brightness", str(cur_bright))
                    except SystemExit:
                        pass
                    last_tick = now    # don't count the paused interval as animation time

            if not paused and timeout > 0 and (now - last_activity) > timeout:
                paused = True
                _turn_off(dev)

            if paused:
                # Cheap poll loop while idle.
                time.sleep(0.2)
                continue

            try:
                frame = mod.render(elapsed, 128, keymap)
            except Exception:
                time.sleep(1.0)
                continue
            if not isinstance(frame, (bytes, bytearray)) or len(frame) != PERKEY_BYTES:
                time.sleep(1.0)
                continue
            try:
                write_bin_attr(dev, "frame", bytes(frame))
                commit(dev)
            except SystemExit:
                # write_bin_attr / commit die() on EACCES etc. Don't bail
                # the loop -- transient permission failures (e.g. mid-rebind)
                # shouldn't kill the detached daemon.
                time.sleep(1.0)
                continue

            elapsed += now - last_tick
            last_tick = now

            # Pace at ~FPS without busy-spinning.
            sleep_for = interval - (time.monotonic() - now)
            if sleep_for > 0:
                time.sleep(sleep_for)
    finally:
        _close_fds(kbd_fds)


def _loop_keepalive(timeout: int = 0) -> None:
    """Idle-aware keepalive for static designs.

    timeout == 0: not spawned (start_keepalive skips it).
    timeout >  0: re-poke `apply` every KEEPALIVE_INTERVAL_S to override the
                  EC's natural idle-dim while the user is active. After
                  `timeout` seconds with no keypress on any
                  /dev/input/by-path/*-event-kbd, mode=off + apply (LEDs
                  go dark). When a key is pressed, re-apply the saved
                  default profile (restores the design frame) and resume.
                  Runs until killed.
    """
    if timeout <= 0:
        return
    dev = find_device()
    kbd_fds = _open_keyboard_event_devices()

    last_activity = time.monotonic()
    last_apply    = time.monotonic()
    leds_on       = True

    try:
        while True:
            now = time.monotonic()

            if kbd_fds and _drain_kbd_events(kbd_fds):
                last_activity = now
                if not leds_on:
                    _restore_static_default(dev)
                    leds_on = True
                    last_apply = now

            if leds_on and (now - last_activity) > timeout:
                _turn_off(dev)
                leds_on = False

            if leds_on and (now - last_apply) >= KEEPALIVE_INTERVAL_S:
                try:
                    write_text_attr(dev, "apply", "1")
                except SystemExit:
                    pass
                last_apply = now

            time.sleep(0.3)
    finally:
        _close_fds(kbd_fds)


def cmd__run_loop(args: argparse.Namespace) -> None:
    # Run as a SESSION leader (start_new_session=True does this for us via
    # the parent's Popen). Ignore SIGHUP so we survive terminal close.
    signal.signal(signal.SIGHUP, signal.SIG_IGN)
    timeout = args.timeout if args.timeout is not None else 0
    if args.anim:
        _loop_animation(args.anim, args.brightness, timeout)
    elif args.keepalive:
        _loop_keepalive(timeout)
    else:
        die("_run-loop needs --anim NAME or --keepalive")


def resolve_key_names(names: Iterable[str], keymap: dict) -> list[int]:
    """Resolve a list of key names to cell indices. Exact match preferred,
    case-insensitive match as fallback ('q' finds a key mapped as 'Q').
    Dies if any are unknown.
    """
    keys = keymap.get("keys", {})
    ci_index = {k.lower(): k for k in keys}
    out, unknown = [], []
    for n in names:
        if n in keys:
            out.append(int(keys[n]))
        elif n.lower() in ci_index:
            out.append(int(keys[ci_index[n.lower()]]))
        else:
            unknown.append(n)
    if unknown:
        die(f"unknown key{'s' if len(unknown) > 1 else ''}: {', '.join(unknown)}\n"
            f"  Run `venator map discover` to teach the CLI which physical key\n"
            f"  corresponds to each of the 128 cells. Run `venator map show`\n"
            f"  to see what's mapped so far.")
    return out


